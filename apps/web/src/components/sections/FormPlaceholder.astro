---
/**
 * FormPlaceholder — caja "form pendiente" para reemplazar embeds de Zoho.
 *
 * Marcado como [TODO] visualmente para que sepamos exactamente qué falta
 * cuando definamos el sistema de formularios (Phase 4 según README).
 */

import Container from "../Container.astro";
import OverlapSection from "../OverlapSection.astro";

interface Props {
  z?: number;
  bg?: string;
  title?: string;
  body?: string;
  formLabel?: string;
}

const {
  z = 6,
  bg = "bg-bg-alt",
  title = "Solicitar Información",
  body = "Recibe el plan de estudios, fechas de inicio y opciones de financiación.",
  formLabel = "Formulario Zoho",
} = Astro.props;
---
<OverlapSection bg={bg} z={z} padding="py-16 md:py-20">
  <Container>
    <div class="grid gap-8 md:grid-cols-[1fr_1fr] items-start">
      <div>
        <span class="inline-flex items-center gap-3 text-[0.74rem] font-bold uppercase tracking-[0.22em] text-brand-blue mb-4">
          <span class="block h-px w-8 bg-current" aria-hidden="true"></span>
          Contacto
        </span>
        <h2 class="font-display text-3xl md:text-5xl font-extrabold uppercase leading-[0.95] text-brand-blue-dark">
          {title}
        </h2>
        <p class="mt-4 text-ink-muted leading-relaxed max-w-[48ch]">{body}</p>
      </div>

      <div class="rounded-3xl bg-white shadow-[0_2px_20px_rgba(0,19,63,0.07)] border border-[rgba(0,19,63,0.06)] p-8 md:p-10">
        <div class="border-2 border-dashed border-ink-light/30 rounded-2xl px-6 py-12 text-center">
          <div class="text-[0.7rem] font-bold uppercase tracking-[0.18em] text-brand-orange mb-2">
            TODO · Pendiente fase CMS / Forms
          </div>
          <div class="text-ink-muted font-body text-sm">
            {formLabel} se integra cuando definamos el stack de formularios.
          </div>
        </div>
      </div>
    </div>
  </Container>
</OverlapSection>
