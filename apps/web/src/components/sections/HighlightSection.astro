---
/**
 * HighlightSection — la ÚNICA sección highlight por página (manual sección 8).
 *
 * - Fondo sólido con color highlight del área (orange/teal/blue)
 * - Copy breve y directo
 * - Máximo 2 CTAs
 */

import Container from "../Container.astro";
import OverlapSection from "../OverlapSection.astro";

type CTA = { label: string; href: string; variant?: "white" | "outline" };

interface Props {
  z?: number;
  /** "orange" para pregrado, "teal" para máster, "blue" para executive */
  color: "orange" | "teal" | "blue" | "purple";
  eyebrow?: string;
  title: string;
  body?: string;
  ctas?: CTA[];
}

const { z = 5, color, eyebrow, title, body, ctas = [] } = Astro.props;

const palette = {
  orange: { bg: "bg-brand-orange-alt", text: "text-white", eyebrow: "text-brand-blue-dark" },
  teal: { bg: "bg-brand-teal-dark", text: "text-white", eyebrow: "text-brand-blue-dark" },
  blue: { bg: "bg-brand-blue", text: "text-white", eyebrow: "text-brand-teal" },
  purple: { bg: "bg-[#7C3AED]", text: "text-white", eyebrow: "text-white" },
}[color];

const ctaVariants = {
  white: "bg-white text-brand-blue-dark hover:bg-bg-alt",
  outline: "bg-transparent border border-white/70 text-white hover:bg-white hover:text-brand-blue-dark",
};
---
<OverlapSection bg={palette.bg} textColor={palette.text} z={z} padding="py-20 md:py-28">
  <Container>
    <div class="max-w-[800px]">
      {eyebrow && (
        <span class={`inline-flex items-center gap-3 text-[0.74rem] font-bold uppercase tracking-[0.22em] ${palette.eyebrow} mb-5`}>
          <span class="block h-px w-8 bg-current" aria-hidden="true"></span>
          {eyebrow}
        </span>
      )}
      <h2 class="font-display font-extrabold uppercase leading-[0.95] text-[clamp(2rem,5vw,4rem)]" set:html={title} />
      {body && <p class="mt-5 text-[1.05rem] md:text-[1.15rem] leading-[1.55] opacity-90 max-w-[60ch]">{body}</p>}
      {ctas.length > 0 && (
        <div class="mt-9 flex flex-wrap gap-3">
          {ctas.slice(0, 2).map((cta) => (
            <a
              href={cta.href}
              class:list={[
                "inline-flex items-center justify-center gap-2 rounded-full px-7 py-3 font-bold text-[0.9rem] tracking-[0.05em] uppercase no-underline transition-all hover:-translate-y-0.5",
                ctaVariants[cta.variant ?? "white"],
              ]}
            >
              {cta.label}
            </a>
          ))}
        </div>
      )}
    </div>
  </Container>
</OverlapSection>
