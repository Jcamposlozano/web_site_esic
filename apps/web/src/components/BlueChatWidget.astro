---
/**
 * BlueChatWidget — burbuja de chat flotante (abajo-izquierda) que embebe a Blue,
 * el agente del Portal Agentes, dentro de un iframe.
 *
 * - El iframe carga de forma diferida: su src solo se asigna al abrir por primera
 *   vez, para no traer a Blue en cada carga de página.
 * - Toda la lógica vive en un <script> vanilla (sin hidratación de framework).
 */
const BLUE_URL = "https://d1s0dg38umawxa.cloudfront.net/esic/student_services";
---

<div id="blue-widget" class="fixed left-4 bottom-4 z-[60] flex flex-col items-start gap-3">
  <!-- Panel del chat -->
  <div
    id="blue-panel"
    class="hidden origin-bottom-left overflow-hidden rounded-2xl bg-white shadow-2xl ring-1 ring-black/10"
    style="width: min(384px, calc(100vw - 2rem)); height: min(600px, calc(100vh - 7rem));"
  >
    <iframe
      id="blue-iframe"
      data-src={BLUE_URL}
      title="Blue — Asistente ESIC"
      class="h-full w-full border-0"
      allow="microphone; clipboard-write"
    ></iframe>
  </div>

  <!-- Botón burbuja -->
  <button
    id="blue-toggle"
    type="button"
    aria-label="Abrir chat con Blue"
    aria-expanded="false"
    class="flex h-14 w-14 items-center justify-center rounded-full bg-brand-blue-dark text-white shadow-xl ring-1 ring-black/10 transition-transform hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-teal"
  >
    <!-- Icono chat -->
    <svg id="blue-icon-open" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
    </svg>
    <!-- Icono cerrar -->
    <svg id="blue-icon-close" class="hidden h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18" />
      <line x1="6" y1="6" x2="18" y2="18" />
    </svg>
  </button>
</div>

<script>
  const toggle = document.getElementById("blue-toggle");
  const panel = document.getElementById("blue-panel");
  const iframe = document.getElementById("blue-iframe") as HTMLIFrameElement | null;
  const iconOpen = document.getElementById("blue-icon-open");
  const iconClose = document.getElementById("blue-icon-close");

  // Origen del iframe de Blue (para postMessage seguro).
  const blueOrigin = iframe ? new URL(iframe.dataset.src || "", location.href).origin : "";
  let panelOpen = false;

  // Reenvía la posición del cursor (de toda la página) al iframe para que Blue
  // la siga. Coords normalizadas [-1,1] relativas al centro del panel de Blue,
  // así el modelo "mira" hacia donde está el mouse en la web. Throttle a 1 frame.
  let aimRaf = 0;
  let lastEvent: MouseEvent | null = null;
  const forwardPointer = (e: MouseEvent) => {
    if (!panelOpen || !iframe) return;
    lastEvent = e;
    if (aimRaf) return;
    aimRaf = requestAnimationFrame(() => {
      aimRaf = 0;
      if (!lastEvent) return;
      const r = panel!.getBoundingClientRect();
      const cx = r.left + r.width / 2;
      const cy = r.top + r.height / 2;
      const nx = Math.max(-1, Math.min(1, (lastEvent.clientX - cx) / (window.innerWidth / 2)));
      const ny = Math.max(-1, Math.min(1, (lastEvent.clientY - cy) / (window.innerHeight / 2)));
      iframe.contentWindow?.postMessage({ type: "blue:pointer", nx, ny }, blueOrigin);
    });
  };

  if (toggle && panel && iframe) {
    toggle.addEventListener("click", () => {
      const isOpen = !panel.classList.contains("hidden");
      if (isOpen) {
        panel.classList.add("hidden");
        panelOpen = false;
        window.removeEventListener("mousemove", forwardPointer);
        toggle.setAttribute("aria-expanded", "false");
        toggle.setAttribute("aria-label", "Abrir chat con Blue");
        iconOpen?.classList.remove("hidden");
        iconClose?.classList.add("hidden");
      } else {
        // Carga diferida: asigna el src la primera vez que se abre.
        if (!iframe.src && iframe.dataset.src) iframe.src = iframe.dataset.src;
        panel.classList.remove("hidden");
        panelOpen = true;
        window.addEventListener("mousemove", forwardPointer);
        toggle.setAttribute("aria-expanded", "true");
        toggle.setAttribute("aria-label", "Cerrar chat con Blue");
        iconOpen?.classList.add("hidden");
        iconClose?.classList.remove("hidden");
      }
    });
  }
</script>
