---
/**
 * Plantilla compartida para las páginas de pregrado específicas
 * (Dirección de Marketing Global y Digital Business), que comparten
 * exactamente la misma estructura del WordPress:
 *   Hero banner → Explora + Form → Beneficios → Testimonios →
 *   Inversión (pricing) → Plan de estudios (tabs por año) + Instituciones.
 *
 * El acento del área es naranja (#FF9600 / #FF8701).
 */
import Container from "../../Container.astro";
import OverlapSection from "../../OverlapSection.astro";
import TestimonioVideo from "./TestimonioVideo.tsx";
import PlanEstudiosTabs, {
  type PlanYear,
  type Institution,
} from "./PlanEstudiosTabs.tsx";

interface PriceFeature {
  text: string;
}

interface Props {
  /** Banner hero (desktop + mobile) */
  heroDesktop: string;
  heroMobile: string;
  heroAlt: string;
  /** Texto del intro "Explora nuestros programas" */
  exploraBody: string;
  /** Título del recuadro del formulario, ej. "Solicita información" */
  formTitle: string;
  /** Copy de los testimonios (2 párrafos) */
  testimoniosBody: string[];
  /** Video de testimonios */
  videoSrc: string;
  /** Precio anual, ej. "$29.469.000" */
  price: string;
  priceFeatures: PriceFeature[];
  /** Plan de estudios por años + instituciones */
  planYears: PlanYear[];
  institutions: Institution[];
  brochureHref: string;
}

const {
  heroDesktop,
  heroMobile,
  heroAlt,
  exploraBody,
  formTitle,
  testimoniosBody,
  videoSrc,
  price,
  priceFeatures,
  planYears,
  institutions,
  brochureHref,
} = Astro.props;

const ArrowRightPath = "M5 12h14M12 5l7 7-7 7";
const ArrowDownPath = "M12 5v14M5 12l7 7 7-7";
const CheckPath = "M20 6L9 17l-5-5";
---

<main>
  <!-- 1. Hero Banner (full-bleed, imagen con overlay) -->
  <section class="relative w-full overflow-hidden leading-none">
    <a href="#formulario" aria-label={heroAlt} class="block">
      <picture class="block w-full">
        <source media="(max-width: 768px)" srcset={heroMobile} type="image/webp" />
        <source media="(min-width: 769px)" srcset={heroDesktop} type="image/webp" />
        <img src={heroDesktop} alt={heroAlt} loading="eager" class="w-full h-auto block object-cover" />
      </picture>
    </a>
    <div class="pointer-events-none absolute inset-0 bg-black/15"></div>
  </section>

  <!-- 2. Explora + Formulario -->
  <OverlapSection bg="bg-white" z={2} padding="pt-20 pb-0 md:pt-24" class="overflow-hidden">
    <Container>
      <div class="grid gap-8 md:gap-12 md:grid-cols-[1fr_1.1fr] items-start">
        <div>
          <h2 class="font-display text-[clamp(2.5rem,5vw,3.5rem)] font-extrabold uppercase leading-[0.95] text-brand-blue mb-4">
            Explora nuestros programas
          </h2>
          <p class="text-ink-muted leading-relaxed mb-6 max-w-[48ch]">{exploraBody}</p>
          <a
            href="#formulario"
            class="inline-flex items-center justify-center gap-2 rounded-full px-7 py-3 font-semibold text-[0.95rem] no-underline transition-all hover:-translate-y-0.5 bg-brand-orange text-white hover:bg-[#E88A00]"
          >
            Solicitar información
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d={ArrowDownPath} /></svg>
          </a>
        </div>

        <!-- Recuadro: en el WP es el form Zoho; aquí placeholder -->
        <div class="rounded-3xl bg-white shadow-[0_20px_60px_rgba(0,19,63,0.12)] p-8 md:p-10">
          <h3 class="font-display text-[1.8rem] font-extrabold uppercase leading-none mb-7 text-brand-orange">{formTitle}</h3>
          <div class="border-2 border-dashed border-ink-light/30 rounded-2xl px-6 py-12 text-center">
            <div class="text-[0.7rem] font-bold uppercase tracking-[0.18em] text-brand-orange mb-2">TODO · Pendiente fase CMS / Forms</div>
            <div class="text-ink-muted font-body text-sm">El formulario Zoho de admisiones se integra cuando definamos el stack de formularios.</div>
          </div>
        </div>
      </div>
    </Container>

    <!-- Banner Becas -->
    <div class="mt-12 mx-auto max-w-[calc(100%-4rem)] md:max-w-[1200px] bg-brand-orange rounded-[24px] px-6 py-8 md:px-10">
      <div class="flex items-center justify-between gap-6 md:gap-8 flex-wrap">
        <h3 class="font-display text-[clamp(1.8rem,3.5vw,2.8rem)] font-extrabold uppercase text-white leading-none m-0">
          Transforma tu futuro con hasta 40% de beca
        </h3>
        <a
          href="/pregrado/becas/"
          class="inline-flex items-center gap-2 rounded-full bg-white text-brand-orange font-bold text-base px-8 py-4 no-underline transition-all hover:-translate-y-0.5 hover:bg-[#F0F0F0] whitespace-nowrap"
        >
          Conoce nuestras becas
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d={ArrowRightPath} /></svg>
        </a>
      </div>
    </div>
  </OverlapSection>

  <!-- 3. Beneficios (grilla 4 columnas con íconos lineales) -->
  <OverlapSection bg="bg-white" z={3} padding="py-16 md:py-20">
    <Container>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-10 md:gap-8 text-center">
        <div class="flex flex-col items-center gap-3">
          <div class="w-[60px] h-[60px] md:w-[90px] md:h-[90px] flex items-center justify-center">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-[50px] h-[50px] md:w-[70px] md:h-[70px] text-brand-orange"><rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" /></svg>
          </div>
          <div>
            <h4 class="font-display text-[1.3rem] md:text-[1.8rem] font-extrabold uppercase leading-none text-brand-blue">4 Años</h4>
            <p class="text-[0.9rem] text-ink mt-1">5 módulos problémicos de 2 meses al año</p>
          </div>
        </div>
        <div class="flex flex-col items-center gap-3">
          <div class="w-[60px] h-[60px] md:w-[90px] md:h-[90px] flex items-center justify-center">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-[50px] h-[50px] md:w-[70px] md:h-[70px] text-brand-orange"><path d="M22 10v6M2 10l10-5 10 5-10 5z" /><path d="M6 12v5c3 3 9 3 12 0v-5" /></svg>
          </div>
          <div>
            <h4 class="font-display text-[1.3rem] md:text-[1.8rem] font-extrabold uppercase leading-none text-brand-blue">Doble Titulación</h4>
            <p class="text-[0.9rem] text-ink mt-1">Colombia y España</p>
          </div>
        </div>
        <div class="flex flex-col items-center gap-3">
          <div class="w-[60px] h-[60px] md:w-[90px] md:h-[90px] flex items-center justify-center">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-[50px] h-[50px] md:w-[70px] md:h-[70px] text-brand-orange"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
          </div>
          <div>
            <h4 class="font-display text-[1.3rem] md:text-[1.8rem] font-extrabold uppercase leading-none text-brand-blue">Medellín</h4>
            <p class="text-[0.9rem] text-ink mt-1">Alto de las Palmas</p>
          </div>
        </div>
        <div class="flex flex-col items-center gap-3">
          <div class="w-[60px] h-[60px] md:w-[90px] md:h-[90px] flex items-center justify-center">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-[50px] h-[50px] md:w-[70px] md:h-[70px] text-brand-orange"><circle cx="12" cy="12" r="10" /><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" /></svg>
          </div>
          <div>
            <h4 class="font-display text-[1.3rem] md:text-[1.8rem] font-extrabold uppercase leading-none text-brand-blue">Inmersión Internacional</h4>
            <p class="text-[0.9rem] text-ink mt-1">Campus de ESIC Madrid</p>
          </div>
        </div>
      </div>
    </Container>
  </OverlapSection>

  <!-- 4. Testimonios (highlight naranja — única sección highlight) -->
  <OverlapSection bg="bg-brand-orange-alt" textColor="text-white" z={4} padding="py-16 md:py-24">
    <Container>
      <div class="grid gap-8 md:gap-12 md:grid-cols-2 items-center">
        <div>
          <h2 class="font-display text-[clamp(2rem,5vw,3.5rem)] font-extrabold uppercase leading-[0.95] mb-4">Testimonios</h2>
          {testimoniosBody.map((p) => <p class="text-base leading-relaxed opacity-90 mb-3">{p}</p>)}
        </div>
        <TestimonioVideo src={videoSrc} client:visible />
      </div>
    </Container>
  </OverlapSection>

  <!-- 5. Inversión / Pricing -->
  <OverlapSection bg="bg-white" z={5} padding="py-16 md:py-24">
    <Container>
      <div class="text-center mb-12">
        <h2 class="font-display text-[clamp(2.5rem,5vw,3.5rem)] font-extrabold uppercase leading-[0.95] text-brand-blue mb-4">Inversión en tu futuro</h2>
        <p class="text-ink-muted text-[1.1rem] max-w-[600px] mx-auto">Conoce el valor de tu formación profesional en ESIC Medellín.</p>
      </div>
      <div class="grid gap-6 md:gap-8 md:grid-cols-2 max-w-[1000px] mx-auto items-start">
        <div class="bg-white rounded-[24px] p-8 md:p-10 shadow-[0_10px_50px_rgba(0,19,63,0.1)] border-2 border-transparent transition-all hover:-translate-y-1 hover:shadow-[0_20px_60px_rgba(0,19,63,0.15)]">
          <div class="text-center mb-8 pb-6 border-b border-[rgba(0,19,63,0.12)]">
            <h3 class="font-display text-2xl font-extrabold uppercase text-brand-blue mb-2">Valor Anual</h3>
            <div class="font-display text-[3rem] font-extrabold text-brand-orange leading-none">
              {price} <span class="text-base font-medium text-ink-muted">COP/año</span>
            </div>
          </div>
          <ul class="mb-8 list-none">
            {priceFeatures.map((f) => (
              <li class="flex items-start gap-3 py-2 text-[0.95rem] text-ink">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange shrink-0 mt-0.5"><path d={CheckPath} /></svg>
                {f.text}
              </li>
            ))}
          </ul>
          <a href="#formulario" class="inline-flex items-center justify-center gap-2 rounded-full px-7 py-3 font-semibold text-[0.95rem] no-underline transition-all hover:-translate-y-0.5 bg-brand-orange text-white hover:bg-[#E88A00]">
            Solicitar información
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d={ArrowDownPath} /></svg>
          </a>
        </div>

        <div class="rounded-[24px] p-8 md:p-10 bg-gradient-to-br from-[#F8F6F2] to-white border-2 border-dashed border-[rgba(0,19,63,0.12)]">
          <div class="w-14 h-14 rounded-2xl bg-[rgba(255,135,1,0.1)] flex items-center justify-center mb-3">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-7 h-7 text-brand-orange"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" /></svg>
          </div>
          <h4 class="font-display text-2xl font-extrabold uppercase text-brand-blue mb-4">Personaliza tu plan de pagos</h4>
          <p class="text-ink-muted text-[0.95rem] leading-relaxed mb-6">Nuestro equipo de admisiones está listo para guiarte. En ESIC puedes personalizar tus pagos de manera mensual.</p>
          <a href="#formulario" class="inline-flex items-center justify-center gap-2 rounded-full px-7 py-3 font-semibold text-[0.95rem] no-underline transition-all hover:-translate-y-0.5 bg-transparent border-2 border-brand-orange text-brand-orange hover:bg-[rgba(255,150,0,0.1)]">
            Agenda una asesoría personalizada
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d={ArrowRightPath} /></svg>
          </a>
        </div>
      </div>
    </Container>
  </OverlapSection>

  <!-- 6. Plan de Estudios -->
  <OverlapSection bg="bg-bg" z={6} padding="py-16 md:py-24" class="overflow-hidden">
    <Container>
      <div class="grid gap-8 md:gap-12 md:grid-cols-[280px_1fr] items-start">
        <div>
          <h2 class="font-display text-[clamp(3rem,6vw,4.5rem)] font-extrabold uppercase leading-[0.9] text-brand-blue">Plan de<br />Estudios</h2>
        </div>
        <PlanEstudiosTabs
          client:visible
          years={planYears}
          institutions={institutions}
          brochureHref={brochureHref}
          programsHref="/pregrado/"
          formHref="#formulario"
        />
      </div>
    </Container>
  </OverlapSection>
</main>
