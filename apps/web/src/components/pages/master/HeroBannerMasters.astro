---
/**
 * HeroBannerMasters — banner full-bleed del contenedor de Másters.
 *
 * Réplica fiel del WP: imagen ancho completo (picture mobile/desktop) con
 * overlay negro y un CTA flotante teal posicionado sobre la imagen
 * (64% / 82% en desktop, centrado abajo en mobile). Hero sin overlap.
 */

interface Props {
  /** Ancla destino del CTA (ej. "#programas") */
  href?: string;
  imageDesktop: string;
  imageMobile: string;
  alt?: string;
  ctaLabel?: string;
}

const {
  href = "#programas",
  imageDesktop,
  imageMobile,
  alt = "Programas de Máster ESIC Medellín",
  ctaLabel = "Ver programas",
} = Astro.props;
---
<section class="hero-banner-masters relative w-full overflow-hidden leading-[0]">
  <a href={href} class="block no-underline" aria-label="Ver programas de máster">
    <picture class="block w-full">
      <source media="(max-width: 768px)" srcset={imageMobile} type="image/webp" />
      <source media="(min-width: 769px)" srcset={imageDesktop} type="image/webp" />
      <img
        src={imageDesktop}
        alt={alt}
        class="block w-full h-auto object-cover object-center"
        loading="eager"
      />
    </picture>
    <!-- Overlay negro (manual: toda imagen con overlay) -->
    <div class="pointer-events-none absolute inset-0 bg-black/25" aria-hidden="true"></div>
  </a>

  <!-- CTA flotante -->
  <a
    href={href}
    class="hero-banner-masters-cta absolute z-10 inline-flex items-center justify-center gap-3 whitespace-nowrap rounded-full bg-brand-teal-dark px-8 py-4 font-body text-[0.85rem] md:text-[1.1rem] font-semibold text-white no-underline shadow-[0_10px_30px_rgba(9,207,144,0.4)] transition-all duration-200 hover:-translate-y-[3px] hover:shadow-[0_15px_40px_rgba(9,207,144,0.5)] hover:bg-[#07B57E]"
  >
    {ctaLabel}
    <svg class="h-5 w-5 rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 5v14M5 12l7 7 7-7" />
    </svg>
  </a>
</section>

<style>
  /* Posicionamiento del CTA flotante — fiel al WP original. */
  .hero-banner-masters-cta {
    left: 50%;
    bottom: 9%;
    transform: translateX(-50%);
  }
  .hero-banner-masters-cta:hover {
    transform: translateX(-50%) translateY(-2px);
  }
  @media (min-width: 769px) {
    .hero-banner-masters-cta {
      left: 64%;
      top: 82%;
      bottom: auto;
      transform: translate(-50%, -50%);
    }
    .hero-banner-masters-cta:hover {
      transform: translate(-50%, -50%) translateY(-3px);
    }
  }
</style>
