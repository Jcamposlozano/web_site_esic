---
/**
 * MasterProgramPage — layout fiel y reutilizable para las 3 páginas de
 * Másters Específicos de ESIC (Digital Business, Customer Experience,
 * Digital Marketing).
 *
 * Replica el patrón del original WordPress:
 *   1. Hero full-bleed (imagen, sin overlap)
 *   2. Explora + Formulario (blanco, overlap 50px)
 *   3. Beneficios (4 iconos, blanco)
 *   4. ESIC Sede Medellín (sección teal — la única HighlightSection — + video)
 *   5. Inversión / precios (blanco, 2 tarjetas)
 *   6. Plan de estudios (crema, acordeón React)
 *
 * Acento del área: TEAL/VERDE (#09CF90 highlight, #0AE4C3 base).
 */
import Container from "../../Container.astro";
import PlanAccordion from "./PlanAccordion.tsx";
import { CONTACT, type MasterProgramData } from "./data";

interface Props {
  data: MasterProgramData;
  /** modo del acordeón del plan de estudios (single = DB, multi = CX/DM) */
  accordionMode?: "single" | "multi";
}

const { data, accordionMode = "single" } = Astro.props;
const { slug } = data;

const formId = `${slug}-formulario`;
const TEAL = "#09CF90";
---

<main class="font-body text-ink">
  {/* ─── 1. HERO (full-bleed, sin overlap) ─── */}
  <section class="block leading-[0]">
    <picture>
      <source media="(max-width: 767px)" srcset={data.hero.mobile} />
      <img
        src={data.hero.desktop}
        alt={data.hero.alt}
        class="block h-auto w-full"
        fetchpriority="high"
      />
    </picture>
  </section>

  {/* ─── 2. EXPLORA + FORM (blanco, overlap) ─── */}
  <section
    id={formId}
    class="relative z-[10] -mt-[50px] rounded-t-[50px] bg-white pb-20 pt-20 md:pt-[80px]"
  >
    <Container>
      <div class="grid items-start gap-12 lg:grid-cols-[1fr_1.1fr]">
        {/* Copy */}
        <div>
          <h2
            class="mb-3 font-display text-[clamp(2rem,4.5vw,3.5rem)] font-semibold uppercase leading-[0.95] text-brand-blue"
          >
            {data.intro.heading}
          </h2>
          {data.intro.paragraphs.map((p) => (
            <p class="mb-3 text-base leading-[1.7] text-ink-muted">{p}</p>
          ))}
          <a
            href={`#${formId}`}
            class="mt-2 inline-flex items-center justify-center gap-2 rounded-full border-2 px-9 py-4 text-[0.85rem] font-semibold uppercase tracking-[0.08em] text-white transition-all duration-200 hover:-translate-y-0.5"
            style={`background:${TEAL};border-color:${TEAL};`}
          >
            Solicitar Información
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="h-4 w-4"
              aria-hidden="true"
            >
              <path d="M12 5v14M5 12l7 7 7-7" />
            </svg>
          </a>
          <div class="mt-6 flex flex-col gap-2">
            <a
              href={CONTACT.phoneHref}
              class="flex items-center gap-2 text-[0.95rem] text-ink-muted no-underline"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="h-4 w-4"
                aria-hidden="true"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.84a16 16 0 0 0 6 6l1.06-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
                />
              </svg>
              {CONTACT.phoneDisplay}
            </a>
            <a
              href={`mailto:${CONTACT.email}`}
              class="flex items-center gap-2 text-[0.95rem] text-ink-muted no-underline"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="h-4 w-4"
                aria-hidden="true"
              >
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
              {CONTACT.email}
            </a>
          </div>
        </div>

        {/* Form card → FormPlaceholder (no construimos forms) */}
        <div
          class="rounded-3xl bg-white p-8 shadow-[0_20px_60px_rgba(0,19,63,0.12)] md:p-10"
        >
          <h3
            class="mb-8 font-display text-[1.8rem] font-semibold uppercase leading-none"
            style={`color:${TEAL};`}
          >
            {data.formTitle}
          </h3>
          <div
            class="rounded-2xl border-2 border-dashed border-ink-light/30 px-6 py-12 text-center"
          >
            <div
              class="mb-2 text-[0.7rem] font-bold uppercase tracking-[0.18em] text-brand-orange"
            >
              TODO · Pendiente fase CMS / Forms
            </div>
            <div class="font-body text-sm text-ink-muted">
              Formulario Zoho se integra cuando definamos el stack de
              formularios.
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  {/* ─── 3. BENEFICIOS (blanco, 4 iconos) ─── */}
  <section
    class="relative z-[5] -mt-[50px] rounded-t-[50px] bg-white py-20 md:py-20"
  >
    <Container class="flex w-full items-center justify-center">
      <div
        class="flex w-full flex-wrap items-center justify-evenly gap-8 text-center"
      >
        {data.benefits.map((b) => (
          <div
            class="flex min-w-[150px] flex-col items-center justify-start gap-3 text-center max-[768px]:w-[calc(50%-0.5rem)] max-[768px]:min-w-0 max-[480px]:w-full"
          >
            <div class="flex h-[70px] w-[70px] items-center justify-center max-[768px]:h-11 max-[768px]:w-11">
              {b.icon === "calendar" && (
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  class="h-[50px] w-[50px] max-[768px]:h-8 max-[768px]:w-8"
                  style={`color:${TEAL};`}
                  aria-hidden="true"
                >
                  <rect x="3" y="4" width="18" height="18" rx="2" />
                  <path d="M16 2v4M8 2v4M3 10h18" />
                </svg>
              )}
              {b.icon === "screen" && (
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  class="h-[50px] w-[50px] max-[768px]:h-8 max-[768px]:w-8"
                  style={`color:${TEAL};`}
                  aria-hidden="true"
                >
                  <rect x="2" y="3" width="20" height="14" rx="2" />
                  <path d="M8 21h8M12 17v4" />
                </svg>
              )}
              {b.icon === "pin" && (
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  class="h-[50px] w-[50px] max-[768px]:h-8 max-[768px]:w-8"
                  style={`color:${TEAL};`}
                  aria-hidden="true"
                >
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
              )}
              {b.icon === "globe" && (
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  class="h-[50px] w-[50px] max-[768px]:h-8 max-[768px]:w-8"
                  style={`color:${TEAL};`}
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="10" />
                  <path
                    d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                  />
                </svg>
              )}
            </div>
            <div class="text-center">
              <h4
                class="font-display text-[1.8rem] font-semibold uppercase leading-none text-brand-blue max-[768px]:text-base"
              >
                {b.label}
              </h4>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  {/* ─── 4. ESIC SEDE MEDELLÍN (HighlightSection teal + video) ─── */}
  <section
    class="relative z-[6] -mt-[50px] rounded-t-[50px] py-20 text-white"
    style={`background:${TEAL};`}
  >
    <Container>
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <h2
            class="mb-3 font-display text-[clamp(2.5rem,5vw,3.5rem)] font-extrabold uppercase leading-[0.95] text-white"
          >
            {data.sede.heading}
          </h2>
          {data.sede.paragraphs.map((p) => (
            <p class="mb-3 text-base leading-[1.7] opacity-90">{p}</p>
          ))}
        </div>
        {/* Video embed de YouTube — embed interactivo, sin overlay (el
            overlay negro del manual aplica a imágenes, no a vídeo reproducible).
            Idéntico al original WordPress. */}
        <div class="relative overflow-hidden rounded-3xl">
          <iframe
            width="100%"
            class="block aspect-video rounded-2xl border-none"
            src={`https://www.youtube.com/embed/${data.sede.youtubeId}`}
            title={data.sede.videoTitle}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"></iframe>
        </div>
      </div>
    </Container>
  </section>

  {/* ─── 5. INVERSIÓN / PRECIOS (blanco, 2 tarjetas) ─── */}
  <section class="relative z-[7] -mt-[50px] rounded-t-[50px] bg-white py-20">
    <Container>
      <div class="mb-12 text-center">
        <h2
          class="mb-4 font-display text-[clamp(2.5rem,5vw,3.5rem)] font-semibold uppercase leading-[0.95] text-brand-blue"
        >
          {data.pricing.heading}
        </h2>
        <p class="mx-auto max-w-[600px] text-[1.1rem] text-ink-muted">
          {data.pricing.subtitle}
        </p>
      </div>
      <div
        class="mx-auto grid max-w-[1000px] items-start gap-8 lg:grid-cols-2"
      >
        {/* Tarjeta de precio */}
        <div
          class="rounded-3xl border-2 border-transparent bg-white p-10 shadow-[0_10px_50px_rgba(0,19,63,0.1)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_60px_rgba(0,19,63,0.15)]"
        >
          <div
            class="mb-8 border-b border-[rgba(0,19,63,0.12)] pb-6 text-center"
          >
            <h3
              class="mb-2 font-display text-[1.5rem] font-semibold uppercase text-brand-blue"
            >
              {data.pricing.cardTitle}
            </h3>
            <div
              class="font-display text-[3rem] font-extrabold leading-none"
              style={`color:${TEAL};`}
            >
              <span>{data.pricing.price} </span>
              <span class="text-base font-medium text-ink-muted">
                {data.pricing.priceCurrency}
              </span>
            </div>
          </div>
          <ul class="mb-8 list-none">
            {data.pricing.features.map((f) => (
              <li
                class="flex items-start gap-3 py-[0.6rem] text-[0.95rem] text-ink"
              >
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  class="mt-0.5 h-5 w-5 flex-shrink-0"
                  style={`color:${TEAL};`}
                  aria-hidden="true"
                >
                  <path d="M20 6L9 17l-5-5" />
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a
            href={`#${formId}`}
            class="inline-flex w-full items-center justify-center gap-2 rounded-full border-2 px-9 py-4 text-[0.85rem] font-semibold uppercase tracking-[0.08em] text-white transition-all duration-200 hover:-translate-y-0.5"
            style={`background:${TEAL};border-color:${TEAL};`}
          >
            Solicitar Información
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="h-4 w-4"
              aria-hidden="true"
            >
              <path d="M12 5v14M5 12l7 7 7-7" />
            </svg>
          </a>
        </div>

        {/* Tarjeta nota plan de pagos */}
        <div
          class="rounded-3xl border-2 border-dashed border-[rgba(0,19,63,0.12)] bg-[linear-gradient(135deg,#F8F6F2_0%,#FFFFFF_100%)] p-10"
        >
          <div
            class="mb-3 flex h-14 w-14 items-center justify-center rounded-2xl"
            style="background:rgba(9,207,144,0.1);"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="h-7 w-7"
              style={`color:${TEAL};`}
              aria-hidden="true"
            >
              <path
                d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"
              />
            </svg>
          </div>
          <h4
            class="mb-4 font-display text-[1.5rem] font-semibold uppercase text-brand-blue"
          >
            {data.pricing.note.title}
          </h4>
          <p class="mb-3 text-[0.95rem] leading-[1.6] text-ink-muted">
            {data.pricing.note.body}
          </p>
          <a
            href={`#${formId}`}
            class="inline-flex w-full items-center justify-center gap-2 rounded-full border-2 bg-transparent px-9 py-4 text-[0.85rem] font-semibold uppercase tracking-[0.08em] transition-all duration-200 hover:-translate-y-0.5 hover:bg-[rgba(9,207,144,0.08)]"
            style={`color:${TEAL};border-color:${TEAL};`}
          >
            {data.pricing.note.ctaLabel}
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="h-4 w-4"
              aria-hidden="true"
            >
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  {/* ─── 6. PLAN DE ESTUDIOS (crema, acordeón) ─── */}
  <section
    id={`${slug}-plan-estudios`}
    class="relative z-[8] -mt-[50px] rounded-t-[50px] bg-bg py-20"
  >
    <Container>
      <div class="mb-14 text-center">
        <h2
          class="font-display text-[clamp(2.5rem,5vw,3.5rem)] font-semibold uppercase leading-[0.95] text-brand-blue"
        >
          {data.plan.heading}
        </h2>
        {data.plan.subtitle && (
          <p
            class="mx-auto mt-4 max-w-[600px] text-[1.05rem] leading-[1.6] text-ink-muted"
          >
            {data.plan.subtitle}
          </p>
        )}
      </div>

      <PlanAccordion
        client:load
        modules={data.plan.modules}
        mode={accordionMode}
      />

      <div class="mt-10 flex flex-wrap justify-center gap-4 max-[480px]:flex-col max-[480px]:items-stretch">
        <a
          href={data.plan.brochureUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 rounded-full border-2 px-9 py-4 text-[0.85rem] font-semibold uppercase tracking-[0.08em] text-white transition-all duration-200 hover:-translate-y-0.5"
          style={`background:${TEAL};border-color:${TEAL};`}
        >
          Brochure del programa
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
        <a
          href="/master"
          class="inline-flex items-center justify-center gap-2 rounded-full border-2 bg-transparent px-9 py-4 text-[0.85rem] font-semibold uppercase tracking-[0.08em] transition-all duration-200 hover:-translate-y-0.5 hover:bg-[rgba(9,207,144,0.08)]"
          style={`color:${TEAL};border-color:${TEAL};`}
        >
          Explorar otros másters
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </Container>
  </section>
</main>
