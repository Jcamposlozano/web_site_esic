const institutions: Institution[] = [
  {
    title: "Digital<br/>Business",
    subtitle: "Título propio español de ESIC University",
    logo: asset("wp/2024/08/cropped-logo-esic-web-1.png"),
    logoAlt: "ESIC",
  },
  {
    title: "Profesional en<br/>Administración de Empresas",
    logo: asset("wp/2024/08/Logo-CEIPA-curvas_logo-CEIPA-gris-01-e1722627736717.png"),
    logoAlt: "CEIPA",
  },
