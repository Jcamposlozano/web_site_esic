const priceFeatures = [
  { text: "4 años de formación" },
  { text: "Doble titulación internacional" },
  { text: "Oportunidad de 6 meses o un año en ESIC University en Madrid" },
  { text: "Acceso a plataformas digitales" },
  { text: "Formación en liderazgo" },
