---
/**
 * /contacto — formulario Zoho real (réplica del popup de footer-global.html).
 *
 * Form: SolicitarInformacinFormulariogeneral110226. Campos y dropdowns
 * condicionales (Pregrado/Máster) fieles al original, autollenado de UTM desde
 * la URL, y redirección a /gracias tras el envío.
 */
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";

const ZOHO_JS =
  "https://forms.zohopublic.com/esicmedellin/form/SolicitarInformacinFormulariogeneral110226/formperma/Rdx6HXS1lMff_KC1PKqlg0BhSQNBDaxDsxdDOnsWmEM/js";
const ZOHO_ACTION =
  "https://forms.zohopublic.com/esicmedellin/form/SolicitarInformacinFormulariogeneral110226/formperma/Rdx6HXS1lMff_KC1PKqlg0BhSQNBDaxDsxdDOnsWmEM/htmlRecords/submit";
---
<Layout
  title="Contacto — ESIC Medellín"
  description="Solicita información sobre los programas de ESIC Medellín. Déjanos tus datos y un asesor te contactará."
  fullBleed
>
  <main>
    <!-- Encabezado -->
    <section class="relative bg-brand-blue-dark text-white pt-32 pb-24 md:pt-40 md:pb-28">
      <Container>
        <div class="max-w-[680px]">
          <span class="inline-flex items-center gap-3 text-[0.74rem] font-bold uppercase tracking-[0.22em] text-brand-teal mb-4">
            <span class="block h-px w-8 bg-current" aria-hidden="true"></span>
            Contacto
          </span>
          <h1 class="font-display font-extrabold uppercase leading-[0.95] text-[clamp(2.75rem,6vw,4.75rem)]">
            Solicita<br />información
          </h1>
          <p class="mt-5 max-w-[52ch] text-[1.1rem] leading-[1.6] text-white/85">
            Déjanos tus datos y un asesor te contactará para resolver tus dudas sobre admisiones,
            programas, becas y financiación.
          </p>
        </div>
      </Container>
    </section>

    <!-- Formulario -->
    <section class="relative z-[2] -mt-[50px] rounded-t-[50px] bg-bg py-16 md:py-20">
      <Container>
        <div class="mx-auto grid max-w-[980px] gap-10 md:grid-cols-[1fr_1.2fr] md:items-start">
          <!-- Lateral info -->
          <aside class="md:pt-4">
            <h2 class="font-display text-2xl font-extrabold uppercase text-brand-blue-dark mb-4">
              Hablemos
            </h2>
            <ul class="space-y-4 text-ink-muted">
              <li class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="mt-0.5 h-5 w-5 shrink-0 text-brand-blue"><path d="M4 4h16v16H4z" opacity="0"/><path d="M22 6l-10 7L2 6"/><rect x="2" y="4" width="20" height="16" rx="2"/></svg>
                <a href="mailto:info@esic.co" class="hover:text-brand-blue transition-colors">info@esic.co</a>
              </li>
              <li class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="mt-0.5 h-5 w-5 shrink-0 text-brand-blue"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>Km 17 vía Las Palmas, Mall La Reserva, Envigado</span>
              </li>
            </ul>
          </aside>

          <!-- Card formulario -->
          <div class="rounded-3xl bg-white p-7 md:p-9 shadow-[0_8px_40px_rgba(0,19,63,0.10)] border border-[rgba(0,19,63,0.06)]">
            <script type="text/javascript" is:inline src={ZOHO_JS}></script>
            <form
              action={ZOHO_ACTION}
              name="esicZohoForm"
              method="POST"
              accept-charset="UTF-8"
              enctype="multipart/form-data"
              id="esicZohoForm"
              class="esic-form"
              onsubmit="zf_ValidateAndSubmit(this, event); return false;"
            >
              <input type="hidden" name="zf_referrer_name" value="" />
              <input type="hidden" name="zf_redirect_url" value="https://esic.co/gracias/" />
              <input type="hidden" name="zc_gad" value="" />

              <div class="esic-form-row">
                <div class="esic-form-group">
                  <label for="c_Name_First">Nombre <em>*</em></label>
                  <input type="text" id="c_Name_First" name="Name_First" maxlength="255" placeholder="Tu nombre" required />
                </div>
                <div class="esic-form-group">
                  <label for="c_Name_Last">Apellido</label>
                  <input type="text" id="c_Name_Last" name="Name_Last" maxlength="255" placeholder="Tu apellido" />
                </div>
              </div>

              <div class="esic-form-group">
                <label for="c_Email">Correo electrónico <em>*</em></label>
                <input type="email" id="c_Email" name="Email" maxlength="255" placeholder="tu@email.com" required />
              </div>

              <div class="esic-form-group">
                <label for="c_PhoneNumber">Teléfono <em>*</em></label>
                <input type="tel" id="c_PhoneNumber" name="PhoneNumber_countrycode" maxlength="20" placeholder="300 123 4567" required />
              </div>

              <div class="esic-form-group">
                <label for="c_Dropdown">Tipo de programa <em>*</em></label>
                <select id="c_Dropdown" name="Dropdown" required onchange="esicContactoToggleProgram(this.value)">
                  <option value="-Select-" disabled selected>-Select-</option>
                  <option value="Pregrado">Pregrado</option>
                  <option value="Máster">Máster</option>
                  <option value="Programa Ejecutivo">Programa Ejecutivo</option>
                  <option value="Empresariales">Empresariales</option>
                  <option value="Level Up">Level Up</option>
                </select>
              </div>

              <div class="esic-form-group" id="c_Dropdown2_group" style="display:none">
                <label for="c_Dropdown2">Programa de interés Máster <em>*</em></label>
                <select id="c_Dropdown2" name="Dropdown2">
                  <option value="-Select-" disabled selected>-Select-</option>
                  <option value="Máster Digital Marketing">Máster en Digital Marketing</option>
                  <option value="Máster Digital Business">Máster en Digital Business</option>
                  <option value="Máster Customer Experience Management">Máster en Customer Experience Management</option>
                </select>
              </div>

              <div class="esic-form-group" id="c_Dropdown4_group" style="display:none">
                <label for="c_Dropdown4">Programa de interés Pregrado <em>*</em></label>
                <select id="c_Dropdown4" name="Dropdown4">
                  <option value="-Select-" disabled selected>-Select-</option>
                  <option value="Dirección de Marketing Global">Dirección de Marketing Global</option>
                  <option value="Digital Business">Digital Business</option>
                </select>
              </div>

              <div class="esic-form-group">
                <label for="c_Dropdown3">Medio de contacto <em>*</em></label>
                <select id="c_Dropdown3" name="Dropdown3" required>
                  <option value="-Select-" disabled selected>-Select-</option>
                  <option value="WhatsApp">WhatsApp</option>
                  <option value="Correo">Correo</option>
                  <option value="Llamada">Llamada</option>
                </select>
              </div>

              <div class="esic-form-checkbox">
                <input type="checkbox" name="TermsConditions" id="c-terms" required />
                <label for="c-terms">
                  Acepto la <a href="/politicas-de-privacidad/" target="_blank" rel="noopener">autorización de datos personales y términos y condiciones</a> <em>*</em>
                </label>
              </div>

              <input type="hidden" name="utm_source" id="utm_source" />
              <input type="hidden" name="utm_medium" id="utm_medium" />
              <input type="hidden" name="utm_campaign" id="utm_campaign" />
              <input type="hidden" name="utm_term" id="utm_term" />
              <input type="hidden" name="utm_content" id="utm_content" />
              <input type="hidden" name="utm_adset_name" id="utm_adset_name" />
              <input type="hidden" name="utm_ad_name" id="utm_ad_name" />

              <button type="submit" class="esic-form-submit">Enviar solicitud</button>
            </form>
          </div>
        </div>
      </Container>
    </section>
  </main>

  <script is:inline>
    // Mostrar/ocultar el dropdown de programa según el tipo seleccionado
    function esicContactoToggleProgram(val) {
      var masterGroup = document.getElementById("c_Dropdown2_group");
      var masterSel = document.getElementById("c_Dropdown2");
      var pregradoGroup = document.getElementById("c_Dropdown4_group");
      var pregradoSel = document.getElementById("c_Dropdown4");

      var showMaster = val === "Máster";
      var showPregrado = val === "Pregrado";

      masterGroup.style.display = showMaster ? "" : "none";
      pregradoGroup.style.display = showPregrado ? "" : "none";
      masterSel.required = showMaster;
      pregradoSel.required = showPregrado;
      if (!showMaster) masterSel.value = "-Select-";
      if (!showPregrado) pregradoSel.value = "-Select-";
    }

    // Autollenado de UTM desde la URL
    document.addEventListener("DOMContentLoaded", function () {
      var params = new URLSearchParams(window.location.search);
      ["utm_source","utm_medium","utm_campaign","utm_term","utm_content","utm_adset_name","utm_ad_name"].forEach(function (p) {
        var value = params.get(p);
        if (!value) return;
        var input = document.querySelector('[name="' + p + '"]') || document.getElementById(p);
        if (input) input.value = value;
      });
    });
  </script>

  <style>
    .esic-form-group { margin-bottom: 1.25rem; }
    .esic-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media (max-width: 480px) { .esic-form-row { grid-template-columns: 1fr; } }
    .esic-form-group label {
      display: block;
      font-family: var(--font-body);
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--color-brand-blue-dark);
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .esic-form-group label em { color: #dc2626; font-style: normal; }
    .esic-form-group input,
    .esic-form-group select {
      width: 100%;
      padding: 0.875rem 1rem;
      border: 1.5px solid #E0E0E0;
      border-radius: 10px;
      font-family: var(--font-body);
      font-size: 1rem;
      color: var(--color-brand-blue-dark);
      background: #fff;
      transition: all 0.2s ease;
      box-sizing: border-box;
    }
    .esic-form-group input:focus,
    .esic-form-group select:focus {
      outline: none;
      border-color: var(--color-brand-blue);
      box-shadow: 0 0 0 3px rgba(0, 71, 233, 0.1);
    }
    .esic-form-checkbox { display: flex; align-items: flex-start; gap: 0.75rem; margin: 1rem 0 1.25rem; }
    .esic-form-checkbox input[type="checkbox"] {
      width: 18px; min-width: 18px; height: 18px; margin: 0.15rem 0 0; flex-shrink: 0;
      accent-color: var(--color-brand-blue); cursor: pointer;
    }
    .esic-form-checkbox label {
      font-family: var(--font-body); font-size: 0.8rem; font-weight: 400;
      color: var(--color-ink-muted); line-height: 1.5; cursor: pointer;
    }
    .esic-form-checkbox label em { color: #dc2626; font-style: normal; }
    .esic-form-checkbox label a { color: var(--color-brand-blue); text-decoration: underline; }
    .esic-form-submit {
      width: 100%; padding: 1rem 2rem; background: var(--color-brand-blue); color: #fff;
      border: none; border-radius: 10px; font-family: var(--font-body); font-size: 1rem;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.02em; cursor: pointer;
      transition: all 0.2s ease;
    }
    .esic-form-submit:hover { background: var(--color-brand-blue-dark); transform: translateY(-1px); box-shadow: 0 12px 30px rgba(0,19,63,0.18); }
  </style>
</Layout>
