---
/**
 * /contacto — formulario Zoho real (componente ContactForm reutilizable).
 */
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import ContactForm from "../components/ContactForm.astro";
---
<Layout
  title="Contacto — ESIC Medellín"
  description="Solicita información sobre los programas de ESIC Medellín. Déjanos tus datos y un asesor te contactará."
  fullBleed
>
  <main>
    <!-- Encabezado -->
    <section class="relative bg-brand-blue-dark text-white pt-32 pb-24 md:pt-40 md:pb-28">
      <Container>
        <div class="max-w-[680px]">
          <span class="inline-flex items-center gap-3 text-[0.74rem] font-bold uppercase tracking-[0.22em] text-brand-teal mb-4">
            <span class="block h-px w-8 bg-current" aria-hidden="true"></span>
            Contacto
          </span>
          <h1 class="font-display font-extrabold uppercase leading-[0.95] text-[clamp(2.75rem,6vw,4.75rem)]">
            Solicita<br />información
          </h1>
          <p class="mt-5 max-w-[52ch] text-[1.1rem] leading-[1.6] text-white/85">
            Déjanos tus datos y un asesor te contactará para resolver tus dudas sobre admisiones,
            programas, becas y financiación.
          </p>
        </div>
      </Container>
    </section>

    <!-- Formulario -->
    <section class="relative z-[2] -mt-[50px] rounded-t-[50px] bg-bg py-16 md:py-20">
      <Container>
        <div class="mx-auto grid max-w-[980px] gap-10 md:grid-cols-[1fr_1.2fr] md:items-start">
          <!-- Lateral info -->
          <aside class="md:pt-4">
            <h2 class="font-display text-2xl font-extrabold uppercase text-brand-blue-dark mb-4">
              Hablemos
            </h2>
            <ul class="space-y-4 text-ink-muted">
              <li class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="mt-0.5 h-5 w-5 shrink-0 text-brand-blue"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 6l-10 7L2 6"/></svg>
                <a href="mailto:info@esic.co" class="hover:text-brand-blue transition-colors">info@esic.co</a>
              </li>
              <li class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="mt-0.5 h-5 w-5 shrink-0 text-brand-blue"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>Km 17 vía Las Palmas, Mall La Reserva, Envigado</span>
              </li>
            </ul>
          </aside>

          <!-- Card formulario -->
          <div class="rounded-3xl bg-white p-7 md:p-9 shadow-[0_8px_40px_rgba(0,19,63,0.10)] border border-[rgba(0,19,63,0.06)]">
            <ContactForm idPrefix="contacto" />
          </div>
        </div>
      </Container>
    </section>
  </main>
</Layout>
