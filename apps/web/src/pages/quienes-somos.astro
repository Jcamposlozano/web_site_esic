---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import CifrasSection from "../components/home/CifrasSection.astro";
import { asset } from "../lib/assets";

const IMG = asset("wp/2026/04");

const valores = [
  {
    accent: "orange",
    title: "Internacionalización",
    body: "Tu transformación es nuestra manera de cambiar el mundo.",
    icon: `<circle cx="13" cy="13" r="11" stroke="#FF9600" stroke-width="1.5" fill="rgba(255,150,0,0.08)"/><ellipse cx="13" cy="13" rx="4.5" ry="11" stroke="#FF9600" stroke-width="1.2"/><line x1="2" y1="13" x2="24" y2="13" stroke="#FF9600" stroke-width="1.2"/>`,
  },
  {
    accent: "blue",
    title: "Innovación",
    body: "Aprendizaje continuo para anticipar y liderar los cambios del mercado.",
    icon: `<path d="M13 4a7 7 0 0 1 4.6 12.3V19H8.4v-2.7A7 7 0 0 1 13 4z" stroke="#0047E9" stroke-width="1.5" fill="rgba(0,71,233,0.08)"/><line x1="9.5" y1="21.5" x2="16.5" y2="21.5" stroke="#0047E9" stroke-width="1.5" stroke-linecap="round"/>`,
  },
  {
    accent: "teal",
    title: "Ética",
    body: "Formamos líderes responsables, con impacto social y empresarial.",
    icon: `<path d="M13 3L3 8v2l10 5 10-5V8L13 3z" stroke="#0AE4C3" stroke-width="1.5" stroke-linejoin="round" fill="rgba(10,228,195,0.08)"/><path d="M5 11.5v5l8 4 8-4v-5" stroke="#0AE4C3" stroke-width="1.3" stroke-linejoin="round"/>`,
  },
  {
    accent: "orange",
    title: "Resultados",
    body: "Metodologías que convierten el conocimiento en acciones medibles.",
    icon: `<rect x="4" y="14" width="4.5" height="9" rx="1.2" stroke="#FF9600" stroke-width="1.5" fill="rgba(255,150,0,0.08)"/><rect x="10.75" y="8" width="4.5" height="15" rx="1.2" stroke="#FF9600" stroke-width="1.5" fill="rgba(255,150,0,0.08)"/><rect x="17.5" y="11" width="4.5" height="12" rx="1.2" stroke="#FF9600" stroke-width="1.5" fill="rgba(255,150,0,0.08)"/>`,
  },
];

const accentBar = {
  orange: "bg-brand-orange",
  blue: "bg-brand-blue",
  teal: "bg-brand-teal",
};
const accentIconBg = {
  orange: "bg-[rgba(255,150,0,0.10)]",
  blue: "bg-[rgba(0,71,233,0.10)]",
  teal: "bg-[rgba(10,228,195,0.10)]",
};

const fundadores = [
  { src: `${IMG}/Fundadores-21-scaled.webp`, alt: "Grupo Bios" },
  { src: `${IMG}/Fundadores-22-scaled.webp`, alt: "Bancolombia" },
  { src: `${IMG}/Fundadores-23-scaled.webp`, alt: "Crystal" },
  { src: `${IMG}/Fundadores-24-scaled.webp`, alt: "Telefónica" },
  { src: `${IMG}/Fundadores-25-scaled.webp`, alt: "Accenture" },
  { src: `${IMG}/Fundadores-26-scaled.webp`, alt: "Postobón" },
];
---
<Layout
  title="Quiénes Somos — ESIC Medellín"
  description="ESIC Medellín: nuestro manifiesto, valores, miembros fundadores y cifras. Una Business & Marketing School que forma transformadores."
  fullBleed
>
  <!-- ==================== HERO BANNER ==================== -->
  <section class="relative w-full overflow-hidden leading-[0]">
    <a href="#manifiesto" aria-label="Ver más sobre ESIC" class="block">
      <picture class="block w-full">
        <source media="(max-width: 768px)" srcset={asset("wp/2026/03/banner-mobile-1-scaled.webp")} type="image/webp" />
        <source srcset={`${IMG}/BANNER-IV-QUIEN-17-scaled.webp`} type="image/webp" />
        <img
          src={`${IMG}/BANNER-IV-QUIEN-17-scaled.webp`}
          alt="Quiénes Somos ESIC"
          loading="eager"
          class="w-full h-auto block"
        />
      </picture>
    </a>
  </section>

  <!-- ==================== MANIFIESTO ==================== -->
  <section
    id="manifiesto"
    class="relative -mt-[50px] max-[768px]:-mt-[30px] rounded-t-[50px] max-[768px]:rounded-t-[30px] bg-bg z-[1] pt-28 pb-24 max-[768px]:pt-16"
  >
    <Container>
      <div class="max-w-[750px] mx-auto text-left">
        <h2
          class="font-display font-extrabold uppercase text-brand-blue-dark text-[clamp(2.5rem,5vw,4rem)] mb-8 block"
        >
          Nuestro Manifiesto
        </h2>
        <p class="text-[clamp(1rem,2vw,1.25rem)] leading-[1.8] text-ink mb-6">
          ESIC Medellín no es solo una escuela. Es un movimiento de mentes valientes. Creemos en el
          marketing con propósito, la economía que transforma, y la tecnología que mejora vidas.
        </p>
        <p class="text-[clamp(1rem,2vw,1.25rem)] leading-[1.8] text-ink mb-6">
          Aquí se piensa distinto. Se actúa con ética. Se impacta con sentido.
        </p>
        <p class="text-[clamp(1rem,2vw,1.25rem)] leading-[1.8] text-ink mb-6">
          No formamos egresados. Formamos transformadores.
        </p>
        <p class="text-[clamp(1rem,2vw,1.25rem)] leading-[1.8] text-ink mb-6">
          Si vienes a encajar, este no es tu lugar. Si vienes a cambiar el juego, bienvenido a casa.
        </p>
        <p
          class="font-display text-[1rem] tracking-[0.2em] uppercase text-ink-muted font-extrabold mt-10"
        >
          ESIC Medellín — diseñando futuros.
        </p>
      </div>
    </Container>
  </section>

  <!-- ==================== VALORES ==================== -->
  <section
    class="relative -mt-[50px] max-[768px]:-mt-[30px] rounded-t-[50px] max-[768px]:rounded-t-[30px] bg-surface z-[2] py-20 max-[768px]:pt-16"
  >
    <Container>
      <div class="mb-12">
        <h2
          class="font-display font-extrabold uppercase text-brand-blue-dark text-[clamp(2.5rem,5vw,3.5rem)] leading-[0.95]"
        >
          Lo que nos <span class="text-brand-orange">mueve</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        {
          valores.map((v) => (
            <article class="group relative bg-surface rounded-3xl overflow-hidden px-6 pt-8 pb-7 shadow-[0_8px_32px_rgba(0,19,63,0.06)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_16px_48px_rgba(0,19,63,0.1)]">
              <span
                class:list={[
                  "absolute top-0 left-0 right-0 h-2 rounded-t-3xl",
                  accentBar[v.accent as keyof typeof accentBar],
                ]}
              />
              <div
                class:list={[
                  "w-14 h-14 rounded-2xl grid place-items-center mb-5",
                  accentIconBg[v.accent as keyof typeof accentIconBg],
                ]}
              >
                <svg
                  viewBox="0 0 26 26"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-[26px] h-[26px]"
                  set:html={v.icon}
                />
              </div>
              <h3 class="font-display font-extrabold uppercase text-[1.4rem] text-ink mb-2.5">
                {v.title}
              </h3>
              <span class="block w-8 h-[3px] bg-ink/20 rounded-sm mb-3" aria-hidden="true" />
              <p class="text-[0.9rem] text-ink-muted leading-[1.5]">{v.body}</p>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- ==================== MIEMBROS FUNDADORES ==================== -->
  <section
    class="relative -mt-[50px] max-[768px]:-mt-[30px] rounded-t-[50px] max-[768px]:rounded-t-[30px] bg-surface z-[3] py-20 max-[768px]:pt-16"
  >
    <Container class="grid lg:grid-cols-[1fr_1.5fr] gap-16 max-[1024px]:gap-12 items-center">
      <div>
        <h2
          class="font-display font-extrabold uppercase text-brand-blue text-[clamp(2.5rem,5vw,4rem)] leading-[0.95]"
        >
          Nuestros<br />Miembros<br />Fundadores
        </h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-6 items-center justify-items-center">
        {
          fundadores.map((f) => (
            <div class="flex items-center justify-center w-full h-[180px] md:h-[220px]">
              <img src={f.src} alt={f.alt} class="w-full h-full object-contain" loading="lazy" />
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- ==================== CIFRAS Y RECONOCIMIENTO ==================== -->
  <CifrasSection z={4} />

  <!-- ==================== SCROLL BREAK (azul oscuro institucional) ==================== -->
  <section
    class="relative -mt-[50px] max-[768px]:-mt-[30px] rounded-t-[50px] max-[768px]:rounded-t-[30px] z-[5] py-20 overflow-hidden"
    style="background:linear-gradient(135deg, #001E47 0%, #00133F 100%)"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      style="background:radial-gradient(circle at 10% 20%, rgba(0,71,233,0.15), transparent 40%),radial-gradient(circle at 90% 80%, rgba(10,228,195,0.08), transparent 40%)"
    >
    </div>
    <Container class="relative z-[1] flex flex-col items-center text-center">
      <h2
        class="font-display font-extrabold uppercase text-white text-[clamp(2.5rem,5vw,4rem)] leading-[0.95] mb-4 max-w-[700px]"
      >
        Transformamos el <span class="text-brand-teal">talento</span> en impacto real
      </h2>
      <p class="text-white/75 text-[1.15rem] max-w-[550px] leading-[1.6]">
        Más de seis décadas formando líderes que entienden el mercado, innovan con propósito y
        construyen el futuro de los negocios.
      </p>
    </Container>
  </section>
</Layout>
