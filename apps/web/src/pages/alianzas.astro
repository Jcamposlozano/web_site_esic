---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/sections/PageHero.astro";
import ContentSection from "../components/sections/ContentSection.astro";
import HighlightSection from "../components/sections/HighlightSection.astro";

const pasos = [
  { step: "01", title: "Activas tu carnet ESIC", body: "Solo necesitas estar matriculado en cualquier programa de ESIC Medellín." },
  { step: "02", title: "Eliges una alianza", body: "Revisa el listado de comercios y servicios aliados con beneficios para estudiantes." },
  { step: "03", title: "Disfrutas el beneficio", body: "Presentas tu carnet en el comercio o usas el código exclusivo para descuentos online." },
];

const alianzas = [
  { name: "Hatsu", logo: null, desc: "Descuentos exclusivos para estudiantes ESIC en bebidas y eventos." },
  { name: "Mall La Reserva", logo: null, desc: "Promociones en restaurantes y servicios del centro comercial donde está nuestro campus." },
  { name: "Cowork ESIC", logo: null, desc: "Tarifas preferenciales para uso de espacios de coworking en el campus." },
  { name: "Programa de empleabilidad", logo: null, desc: "Acceso prioritario a ofertas laborales de empresas aliadas del ecosistema." },
];
---
<Layout title="Alianzas Estudiantes — ESIC Medellín">
  <PageHero
    eyebrow="Estudiantes ESIC"
    title="Beneficios &<br /><span class='text-brand-teal'>alianzas</span>"
    subtitle="Acceso preferente a comercios, servicios y experiencias del ecosistema. Pensado para estudiantes activos de ESIC Medellín."
    ctas={[{ label: "Ver alianzas", href: "#alianzas" }]}
    eyebrowColor="text-brand-teal"
  />

  <ContentSection
    z={2}
    eyebrow="Tres pasos. Listo."
    title="Cómo funciona"
  >
    <div class="grid gap-6 md:grid-cols-3 mt-6">
      {pasos.map((p) => (
        <article class="bg-white rounded-3xl p-8 border border-[rgba(0,19,63,0.06)] shadow-[0_2px_20px_rgba(0,19,63,0.05)]">
          <div class="font-display text-4xl font-extrabold text-brand-blue leading-none mb-4">{p.step}</div>
          <h3 class="font-display text-lg font-extrabold uppercase text-brand-blue-dark mb-2">{p.title}</h3>
          <p class="text-ink-muted leading-relaxed">{p.body}</p>
        </article>
      ))}
    </div>
  </ContentSection>

  <ContentSection
    z={3}
    bg="bg-bg-alt"
    eyebrow="Nuestras alianzas"
    title="Comercios & servicios aliados"
  >
    <div id="alianzas" class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 mt-6">
      {alianzas.map((a) => (
        <article class="bg-white rounded-3xl p-8 border border-[rgba(0,19,63,0.06)] shadow-[0_2px_20px_rgba(0,19,63,0.05)]">
          <div class="w-12 h-12 rounded-2xl bg-brand-blue/10 grid place-items-center mb-4">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-blue w-6 h-6">
              <path d="M20 7H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1Z"/>
              <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
            </svg>
          </div>
          <h3 class="font-display text-xl font-extrabold uppercase text-brand-blue-dark mb-3">{a.name}</h3>
          <p class="text-ink-muted leading-relaxed">{a.desc}</p>
        </article>
      ))}
    </div>
  </ContentSection>

  <HighlightSection
    z={4}
    color="blue"
    eyebrow="¿Eres comercio o marca?"
    title="Únete a nuestra red<br />de alianzas"
    body="Si tu empresa quiere conectar con estudiantes y profesionales del ecosistema ESIC, conversemos."
    ctas={[{ label: "Hablar con ESIC", href: "/quienes-somos/" }]}
  />
</Layout>
