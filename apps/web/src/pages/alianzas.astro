---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import AlianzasGrid from "../components/pages/eventos/AlianzasGrid.tsx";
import { asset } from "../lib/assets";

const title = "Alianzas — Beneficios para la comunidad ESIC Medellín";
const description =
  "Marcas que reconocen y premian a la comunidad ESIC Medellín. Activa beneficios en bienestar, gastronomía, cultura y servicios con tu carné institucional.";

const steps = [
  {
    num: "01",
    title: "Explora las alianzas",
    body: "Filtra por categoría y revisa el detalle de cada beneficio: condiciones, vigencia y ubicación.",
    icon: `<circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>`,
  },
  {
    num: "02",
    title: "Presenta tu carné ESIC",
    body: "Tu carné institucional vigente es la llave. Algunos aliados también aceptan código exclusivo.",
    icon: `<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 10h18M8 15h2"/>`,
  },
  {
    num: "03",
    title: "Disfruta tu beneficio",
    body: "Aplica al instante. Algunos beneficios tienen días u horarios específicos: revisa cada ficha.",
    icon: `<path d="M20 12V5a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v14l3-3 3 3 3-3 3 3"/><path d="M16 16l4 4M20 16l-4 4"/>`,
  },
];
---
<Layout title={title} description={description} fullBleed>
  <main class="esic-alianzas bg-bg">
    <!-- HERO BANNER -->
    <section class="relative block overflow-hidden bg-bg leading-[0]">
      <a href="#alianzas-grid" aria-label="Ver alianzas ESIC" class="block cursor-pointer">
        <picture>
          <source media="(max-width: 768px)" srcset={asset("wp/2026/05/BANNER-ALIANZAS-02-scaled.webp")} type="image/webp" />
          <source srcset={asset("wp/2026/05/BANNER-ALIANZAS-01.webp")} type="image/webp" />
          <img
            src={asset("wp/2026/05/BANNER-ALIANZAS-01.webp")}
            alt="Banner alianzas ESIC"
            class="block h-auto w-full align-bottom"
            fetchpriority="high"
          />
        </picture>
      </a>
    </section>

    <!-- HOW IT WORKS -->
    <section class="relative z-[2] -mt-[50px] rounded-t-[40px] bg-bg pb-[clamp(3rem,6vw,5rem)] pt-[clamp(4.5rem,8vw,7rem)]">
      <Container class="max-w-[1180px]">
        <div class="mx-auto mb-[3.2rem] max-w-[720px] text-center">
          <div class="ali-tag mb-[0.9rem] inline-flex items-center gap-2 text-[0.74rem] font-bold uppercase tracking-[0.22em] text-brand-blue">
            Cómo funciona
          </div>
          <h2 class="font-display text-[clamp(2.4rem,5vw,3.6rem)] font-extrabold uppercase text-brand-blue-dark">Tres pasos. Listo.</h2>
          <p class="mt-[0.9rem] text-[1.05rem] text-[#5C6477]">Activar un beneficio es simple: identifica la alianza, presenta tu carné institucional y disfruta.</p>
        </div>

        <div class="grid grid-cols-1 gap-[1.4rem] md:grid-cols-3">
          {steps.map((s) => (
            <div class="ali-step relative overflow-hidden rounded-[24px] border border-[#E7E2D8] bg-white p-[2rem_1.8rem] transition-all hover:-translate-y-1 hover:shadow-[0_22px_40px_-22px_rgba(0,19,63,0.18)]">
              <div class="absolute right-[1.4rem] top-4 font-display text-[4rem] font-extrabold leading-none text-brand-blue opacity-[0.18]">{s.num}</div>
              <div class="mb-[1.2rem] inline-flex h-[46px] w-[46px] items-center justify-center rounded-[12px] bg-[rgba(0,71,233,0.10)] text-brand-blue">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
              </div>
              <h3 class="mb-[0.55rem] font-display text-[1.5rem] font-extrabold uppercase text-brand-blue-dark">{s.title}</h3>
              <p class="text-[0.95rem] leading-[1.55] text-[#5C6477]">{s.body}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- GRID + FILTERS + MODAL -->
    <section id="alianzas-grid" class="relative z-[3] -mt-[50px] rounded-t-[40px] bg-white pb-[clamp(5rem,9vw,8rem)] pt-[clamp(4.5rem,8vw,7rem)]">
      <Container class="max-w-[1180px]">
        <AlianzasGrid client:load />
      </Container>
    </section>
  </main>
</Layout>

<style>
  .esic-alianzas .ali-tag::before {
    content: "";
    width: 22px;
    height: 2px;
    background: var(--color-brand-blue);
    border-radius: 2px;
  }
</style>

<script>
  // Smooth scroll del banner hacia el grid de alianzas
  document.querySelectorAll('.esic-alianzas a[href="#alianzas-grid"]').forEach((link) => {
    link.addEventListener("click", (e) => {
      const target = document.getElementById("alianzas-grid");
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });
</script>
