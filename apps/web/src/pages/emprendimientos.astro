---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import EmprendimientosGrid from "../components/pages/eventos/EmprendimientosGrid.tsx";

const title = "Emprendimientos — Comunidad ESIC Medellín";
const description =
  "Conoce los proyectos y emprendimientos que están construyendo los estudiantes y egresados de ESIC Medellín. Negocios reales, ideas en movimiento.";
---
<Layout title={title} description={description} fullBleed>
  <main class="bg-bg">
    <!-- HERO -->
    <section class="relative flex min-h-[70vh] items-end overflow-hidden bg-brand-blue-dark pb-32 pt-36 md:pb-[8rem]">
      <img
        src="/images/wp/2026/04/areas-comunes-03.webp"
        alt=""
        class="absolute inset-0 z-0 h-full w-full object-cover"
        fetchpriority="high"
      />
      <div class="absolute inset-0 z-[1] bg-gradient-to-br from-[rgba(0,19,63,0.82)] to-[rgba(0,19,63,0.55)]"></div>
      <Container class="relative z-[2]">
        <p class="mb-8 text-[0.85rem] tracking-[0.04em] text-white/65">
          <a href="/" class="text-white/65 transition-colors hover:text-brand-teal">Inicio</a>
          <span class="mx-1.5">/</span>Emprendimientos
        </p>
        <div class="max-w-[720px]">
          <span class="mb-[1.2rem] inline-block text-[0.8rem] font-semibold uppercase tracking-[0.12em] text-brand-teal">
            Comunidad ESIC Medellín
          </span>
          <h1 class="mb-6 font-display text-[clamp(3rem,7vw,5.5rem)] font-extrabold uppercase leading-[0.95] text-white">
            Hecho por <span class="text-brand-teal">nuestros estudiantes</span>
          </h1>
          <p class="max-w-[580px] text-[1.15rem] leading-[1.6] text-white/85">
            Conoce los proyectos y emprendimientos que están construyendo quienes pasan por nuestras aulas. Negocios reales, ideas en movimiento.
          </p>
        </div>
      </Container>
    </section>

    <!-- INTRO + FILTROS + GRID -->
    <section class="relative z-[2] -mt-[50px] rounded-t-[50px] bg-bg pb-20 pt-20 md:pt-24">
      <Container>
        <div class="mx-auto mb-12 max-w-[760px] text-center">
          <p class="text-[1.15rem] leading-[1.65] text-ink-muted">
            Este escaparate reúne emprendimientos creados por estudiantes y egresados de ESIC. Una muestra viva de cómo la formación se traduce en negocios, marcas y proyectos.
          </p>
        </div>

        <EmprendimientosGrid client:load />
      </Container>
    </section>

    <!-- CTA -->
    <section class="relative z-[3] -mt-[50px] rounded-t-[50px] bg-brand-blue py-20 text-center md:py-24">
      <Container>
        <div class="mx-auto max-w-[680px]">
          <h2 class="mb-[1.2rem] font-display text-[clamp(2.5rem,5vw,3.5rem)] font-extrabold uppercase leading-[0.95] text-white">
            ¿Tu emprendimiento debería estar aquí?
          </h2>
          <p class="mb-8 text-[1.1rem] leading-[1.6] text-white/85">
            Si eres estudiante o egresado de ESIC y estás construyendo algo, queremos conocerlo y ayudarte a contarlo.
          </p>
          <a
            href="/contacto"
            class="inline-flex items-center gap-2.5 rounded-full bg-white px-8 py-4 text-[0.85rem] font-bold uppercase tracking-[0.06em] text-brand-blue no-underline transition-all hover:-translate-y-0.5 hover:bg-[#F0F0F0]"
          >
            Cuéntanos tu historia
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
          </a>
        </div>
      </Container>
    </section>
  </main>
</Layout>
