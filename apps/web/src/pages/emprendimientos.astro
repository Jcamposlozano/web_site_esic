---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/sections/PageHero.astro";
import ContentSection from "../components/sections/ContentSection.astro";
import HighlightSection from "../components/sections/HighlightSection.astro";

const filtros = ["Todo", "Tech", "Retail", "Servicios", "Marketing", "Sostenibilidad"];

const proyectos = [
  { tag: "Tech", title: "Plataforma de logística IA", desc: "Startup de optimización de rutas con IA, fundada por egresados ESIC." },
  { tag: "Retail", title: "Marca de moda sostenible", desc: "E-commerce de moda con cadena de producción local y trazable." },
  { tag: "Marketing", title: "Agencia de contenido B2B", desc: "Estudio especializado en content marketing para SaaS." },
  { tag: "Servicios", title: "Consultora de transformación digital", desc: "Acompañamiento a pymes en digitalización de procesos." },
  { tag: "Sostenibilidad", title: "Marketplace de productos zero waste", desc: "Plataforma de comercio circular para Latinoamérica." },
  { tag: "Tech", title: "App de salud mental", desc: "App con IA conversacional para acompañamiento emocional." },
];
---
<Layout title="Emprendimientos — ESIC Medellín">
  <PageHero
    eyebrow="Comunidad ESIC Medellín"
    title="Hecho por<br />nuestros <span class='text-brand-teal'>estudiantes</span>"
    subtitle="Emprendimientos, productos y proyectos creados por estudiantes y egresados de ESIC Medellín. Ecosistema que conecta talento con oportunidades."
    ctas={[{ label: "Sumar mi proyecto", href: "#sumar" }]}
    eyebrowColor="text-brand-teal"
  />

  <ContentSection
    z={2}
    eyebrow="Comunidad ESIC"
    title="Proyectos de la red"
  >
    <div class="flex flex-wrap gap-2 mb-8">
      {filtros.map((f, i) => (
        <button
          type="button"
          class:list={[
            "text-[0.78rem] uppercase tracking-[0.08em] font-semibold px-4 py-2 rounded-full transition-colors",
            i === 0
              ? "bg-brand-blue text-white"
              : "bg-white text-brand-blue-dark border border-brand-blue-dark/15 hover:bg-bg",
          ]}
        >
          {f}
        </button>
      ))}
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {proyectos.map((p) => (
        <article class="group bg-white rounded-3xl p-7 border border-[rgba(0,19,63,0.06)] shadow-[0_2px_20px_rgba(0,19,63,0.05)] transition-transform hover:-translate-y-1">
          <span class="inline-flex items-center text-[0.65rem] font-bold uppercase tracking-[0.16em] text-brand-teal-dark bg-brand-teal/15 rounded-full px-3 py-1 mb-4">
            {p.tag}
          </span>
          <h3 class="font-display text-lg font-extrabold uppercase text-brand-blue-dark mb-2 leading-tight">{p.title}</h3>
          <p class="text-ink-muted text-[0.95rem] leading-relaxed mb-4">{p.desc}</p>
          <span class="inline-flex items-center gap-2 text-[0.78rem] font-bold uppercase tracking-[0.06em] text-brand-blue group-hover:text-brand-blue-dark transition-colors">
            Ver caso
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </article>
      ))}
    </div>
  </ContentSection>

  <HighlightSection
    z={3}
    color="teal"
    eyebrow="¿Tu emprendimiento debería estar aquí?"
    title="Súmate al directorio"
    body="Si eres estudiante o egresado ESIC y tienes un proyecto activo, nos encantaría conocerlo."
    ctas={[{ label: "Postular mi proyecto", href: "/quienes-somos/" }]}
  />
</Layout>
