---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/sections/PageHero.astro";
import ContentSection from "../components/sections/ContentSection.astro";
import BeneficiosGrid from "../components/sections/BeneficiosGrid.astro";
import HighlightSection from "../components/sections/HighlightSection.astro";
import ScrollBreak from "../components/sections/ScrollBreak.astro";
import FormPlaceholder from "../components/sections/FormPlaceholder.astro";

const ejes = [
  {
    title: "Marketing estratégico",
    body: "Investigación de mercados, plan de marketing, branding, comunicación 360° y métricas de impacto.",
  },
  {
    title: "Mercados internacionales",
    body: "Estrategia global, comercio exterior, segmentación cultural y posicionamiento en mercados emergentes.",
  },
  {
    title: "Negocios digitales",
    body: "E-commerce, marketing digital, analítica avanzada, performance, CRM y experiencia del consumidor.",
  },
  {
    title: "Liderazgo & gestión",
    body: "Dirección comercial, gestión de equipos, finanzas para no financieros, ética y sostenibilidad.",
  },
];
---
<Layout title="Pregrado en Dirección de Marketing Global — ESIC Medellín">
  <PageHero
    eyebrow="Pregrado · 4 años · Doble titulación"
    title="Dirección de<br /><span class='text-brand-orange'>Marketing Global</span>"
    subtitle="Forma profesionales capaces de liderar estrategias de marketing en mercados globales, con visión cultural, capacidad analítica y dominio de las herramientas digitales."
    ctas={[
      { label: "Solicitar Información", href: "#contacto" },
      { label: "Conocer becas", href: "/pregrado/becas/", variant: "outline" },
    ]}
    image="/images/wp/2026/03/banner-direccion-marketing-global-desktop.webp"
    imageMobile="/images/wp/2026/03/banner-direccion-marketing-global-mobile.webp"
  />

  <BeneficiosGrid
    z={2}
    eyebrow="Lo esencial"
    title="Todo lo que necesitas saber"
    items={[
      { value: "4 años", label: "Duración", color: "orange" },
      { value: "Medellín", label: "Campus presencial", color: "blue" },
      { value: "ESIC + CEIPA", label: "Doble titulación", color: "teal" },
      { value: "Madrid", label: "Inmersión internacional", color: "purple" },
    ]}
  />

  <ContentSection
    z={3}
    bg="bg-bg-alt"
    eyebrow="Plan de estudios"
    eyebrowColor="text-brand-orange"
    title="Cuatro ejes formativos"
  >
    <div class="grid gap-6 md:grid-cols-2 mt-6">
      {ejes.map((e) => (
        <article class="bg-white rounded-3xl p-8 shadow-[0_2px_20px_rgba(0,19,63,0.05)] border border-[rgba(0,19,63,0.05)]">
          <h3 class="font-display text-xl font-extrabold uppercase text-brand-blue-dark mb-3">{e.title}</h3>
          <div class="w-10 h-[2px] bg-brand-orange mb-4"></div>
          <p class="text-ink-muted leading-[1.6]">{e.body}</p>
        </article>
      ))}
    </div>
  </ContentSection>

  <ScrollBreak
    z={4}
    eyebrow="Networking corporativo"
    title="Construyes portafolio,<br />criterio y conexiones reales<br />desde el primer semestre"
    cta={{ label: "Conoce el campus", href: "/campus/" }}
  />

  <HighlightSection
    z={5}
    color="orange"
    eyebrow="Inversión en tu futuro"
    title="Hasta 40% de beca por excelencia académica"
    body="Aplica desde tu proceso de admisión. Beneficios adicionales para movilidad nacional, hermanos matriculados y antiguos alumnos ESIC."
    ctas={[
      { label: "Aplicar a beca", href: "/pregrado/becas/" },
      { label: "Solicitar info", href: "#contacto", variant: "outline" },
    ]}
  />

  <FormPlaceholder z={6} title="Solicita información del Pregrado en Marketing Global" />
</Layout>
