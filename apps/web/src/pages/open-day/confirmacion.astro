---
import Layout from "../../layouts/Layout.astro";
import ContentSection from "../../components/sections/ContentSection.astro";
---
<Layout title="¡Registro confirmado! · Open Day ESIC Medellín">
  <ContentSection z={1} bg="bg-bg" padding="py-20 md:py-28">
    <div class="max-w-[720px] mx-auto text-center">
      <div class="inline-flex w-20 h-20 rounded-full bg-brand-teal grid place-items-center mb-8">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      </div>
      <span class="inline-flex items-center gap-3 text-[0.74rem] font-bold uppercase tracking-[0.22em] text-brand-blue mb-3">
        <span class="block h-px w-8 bg-current" aria-hidden="true"></span>
        Open Day · Confirmación
      </span>
      <h1 class="font-display text-5xl md:text-6xl font-extrabold uppercase text-brand-blue-dark leading-[0.95]">
        ¡Registro<br />confirmado!
      </h1>
      <p class="mt-5 text-[1.05rem] text-ink-muted leading-relaxed max-w-[55ch] mx-auto">
        Te esperamos el sábado para vivir la experiencia ESIC. Recibirás un correo con todos los
        detalles y un recordatorio el día antes del evento.
      </p>
    </div>
  </ContentSection>

  <ContentSection z={2} bg="bg-white" padding="py-12 md:py-16">
    <div class="grid gap-6 md:grid-cols-2 max-w-[820px] mx-auto">
      <article class="bg-bg-alt rounded-3xl p-8">
        <h3 class="font-display text-xl font-extrabold uppercase text-brand-blue-dark mb-4">Detalles del evento</h3>
        <ul class="space-y-3 text-ink leading-relaxed">
          <li><strong class="text-brand-blue-dark">Fecha:</strong> Sábado 30 de mayo de 2026</li>
          <li><strong class="text-brand-blue-dark">Hora:</strong> 9:00 am – 12:00 pm</li>
          <li><strong class="text-brand-blue-dark">Lugar:</strong> Campus ESIC Medellín</li>
          <li><strong class="text-brand-blue-dark">Dirección:</strong> Km 17 vía Las Palmas, Mall La Reserva, Envigado</li>
        </ul>
      </article>
      <article class="bg-bg-alt rounded-3xl p-8">
        <h3 class="font-display text-xl font-extrabold uppercase text-brand-blue-dark mb-4">Próximos pasos</h3>
        <ul class="space-y-3 text-ink leading-relaxed">
          <li><a href="https://www.google.com/calendar" target="_blank" rel="noopener" class="text-brand-blue underline">Agregar a Google Calendar</a></li>
          <li><a href="https://www.google.com/maps/place/Mall+La+Reserva,+Envigado" target="_blank" rel="noopener" class="text-brand-blue underline">Ver en Google Maps</a></li>
          <li><a href="https://wa.me/573000000000" target="_blank" rel="noopener" class="text-brand-blue underline">Contactar por WhatsApp</a></li>
        </ul>
      </article>
    </div>
    <div class="text-center mt-12">
      <a href="/" class="inline-flex items-center justify-center rounded-full bg-brand-blue text-white text-[0.85rem] font-bold uppercase tracking-[0.06em] px-7 py-3 hover:bg-brand-blue-dark transition-colors no-underline">
        Volver al inicio
      </a>
    </div>
  </ContentSection>
</Layout>
