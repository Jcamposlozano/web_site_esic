---
import Layout from "../layouts/Layout.astro";

/**
 * Level Up — página índice (réplica fiel de level-up-elementor.html).
 *
 * Diseño oscuro autocontenido. Acento MORADO (#A78BFA / #7C3AED) en lugar del
 * teal del original WP. Hero limpio (logo + título), Agenda 2026 con 3 niveles,
 * y panel CTA final.
 *
 * fullBleed: el hero arranca pegado arriba (el Nav flota encima).
 */

const niveles = [
  {
    title: "Nivel 1 – Iniciador",
    body: "Comprende la lógica de la automatización y la IA aplicada al negocio. Aprende cómo funcionan los workflows e identifica oportunidades reales en tu entorno profesional.",
  },
  {
    title: "Nivel 2 – Integrador",
    body: "Diseña y construye automatizaciones completas conectando herramientas, datos y APIs. Integra sistemas y aplica IA para optimizar procesos reales de negocio.",
  },
  {
    title: "Nivel 3 – Optimizador",
    body: "Implementa un caso real end-to-end con visión estratégica. Diseña arquitectura, gestiona errores y construye soluciones escalables.",
  },
];
---
<Layout title="Level Up — ESIC Medellín" fullBleed>
  <div class="esic-level-up">
    <!-- ══ HERO ══ -->
    <section class="elup-hero">
      <div class="elup-container">
        <div class="elup-hero-content">
          <img
            src="/images/wp/2026/03/logo-level-up-scaled.png"
            alt="Level Up by ESIC"
            class="elup-hero-logo"
            width="320"
            height="100"
          />
          <h1>Aprende, aplica<br />y <span>lidera</span></h1>
          <p class="elup-hero-sub">
            Cursos cortos de formación intensiva para actualizar
            habilidades y acelerar tu carrera.
          </p>
        </div>
      </div>
    </section>

    <!-- ══ AGENDA ══ -->
    <section class="elup-section" id="agenda">
      <div class="elup-container">
        <div class="elup-agenda-wrap">
          <div class="elup-agenda-header">
            <span class="elup-section-tag">Próximos Level Up</span>
            <h2 class="elup-agenda-title">Agenda 2026</h2>
            <p class="elup-agenda-sub">
              Todos los Level Up son presenciales. Entrena las habilidades más
              demandadas en sesiones intensivas.
            </p>
          </div>
          <div class="elup-event-grid">
            {niveles.map((n) => (
              <article class="elup-event-card">
                <div class="elup-event-prox">Próximamente</div>
                <h3>{n.title}</h3>
                <p>{n.body}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ══ CTA FINAL ══ -->
    <section class="elup-section elup-section-cta">
      <div class="elup-container">
        <div class="elup-cta-panel">
          <div>
            <h2>¿Listo para tu<br />próximo Level Up?</h2>
            <p>Reserva tu cupo y recibe información de fechas, ponentes y temáticas.</p>
          </div>
          <a
            class="elup-btn elup-btn-dark"
            href="/level-up/estrategia-marketing-digital"
          >
            Quiero inscribirme →
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .esic-level-up {
    --lup-dark: #00101f;
    --lup-navy: #00133f;
    --lup-purple: #a78bfa;
    --lup-purple-solid: #7c3aed;
    --lup-white: #ffffff;
    --lup-muted: rgba(255, 255, 255, 0.62);
    --lup-border: rgba(255, 255, 255, 0.1);
    font-family: var(--font-body);
    color: var(--lup-white);
    line-height: 1.6;
    overflow-x: hidden;
    width: 100%;
    background: var(--lup-dark);
  }
  .esic-level-up :where(h1, h2, h3, h4) {
    font-family: var(--font-display);
    font-weight: 800;
    margin: 0;
    text-transform: none;
  }
  .esic-level-up p { margin: 0; }

  /* Layout */
  .elup-container {
    width: min(1100px, 90%);
    margin: 0 auto;
  }
  .elup-section {
    padding: 3rem 0;
    position: relative;
  }
  .elup-section-cta {
    padding-bottom: 6rem;
  }

  /* Buttons */
  .elup-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.9rem 2rem;
    border-radius: 999px;
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: all 0.22s;
    text-decoration: none;
    line-height: 1;
  }
  .elup-btn-dark {
    background: var(--lup-navy);
    color: var(--lup-white);
  }
  .elup-btn-dark:hover {
    background: #001a5c;
    transform: translateY(-2px);
  }

  /* ── HERO ── */
  .elup-hero {
    min-height: auto;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    background: var(--lup-dark);
    padding: 14rem 0 4rem;
  }
  .elup-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 15% 40%, rgba(124, 58, 237, 0.3) 0%, transparent 55%),
      radial-gradient(ellipse at 85% 60%, rgba(167, 139, 250, 0.16) 0%, transparent 50%);
  }
  .elup-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 820px;
    margin: 0 auto;
  }
  .elup-hero-logo {
    display: block;
    width: auto;
    height: 100px;
    margin: 0 auto 2rem;
    object-fit: contain;
  }
  .elup-hero h1 {
    font-size: clamp(3.8rem, 10vw, 7.5rem);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.9;
    color: var(--lup-white);
    margin-bottom: 1.5rem;
  }
  .elup-hero h1 span { color: var(--lup-purple); }
  .elup-hero-sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--lup-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ── AGENDA ── */
  .elup-agenda-wrap {
    background: linear-gradient(135deg, #1a1033 0%, #150b2e 100%);
    border-radius: 40px;
    padding: 3.5rem;
    position: relative;
    overflow: hidden;
  }
  .elup-agenda-wrap::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 10% 20%, rgba(124, 58, 237, 0.22), transparent 45%),
      radial-gradient(circle at 90% 80%, rgba(167, 139, 250, 0.12), transparent 45%);
  }
  .elup-agenda-header {
    position: relative;
    z-index: 1;
    margin-bottom: 2.5rem;
  }
  .elup-section-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--lup-purple);
    margin-bottom: 0.6rem;
  }
  .elup-section-tag::before {
    content: "";
    width: 20px;
    height: 2px;
    background: var(--lup-purple);
    border-radius: 2px;
  }
  .elup-agenda-title {
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: var(--lup-white);
    margin-bottom: 0.5rem;
  }
  .elup-agenda-sub {
    font-size: 0.95rem;
    color: var(--lup-muted);
  }
  .elup-event-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .elup-event-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--lup-border);
    border-radius: 22px;
    padding: 1.8rem;
    backdrop-filter: blur(8px);
    transition: transform 0.3s, border-color 0.3s;
  }
  .elup-event-card:hover {
    transform: translateY(-4px);
    border-color: rgba(167, 139, 250, 0.4);
  }
  .elup-event-prox {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--lup-purple);
    margin-bottom: 1rem;
  }
  .elup-event-card h3 {
    font-size: 1.25rem;
    text-transform: uppercase;
    color: var(--lup-white);
    margin-bottom: 0.5rem;
  }
  .elup-event-card p {
    font-size: 0.88rem;
    color: var(--lup-muted);
    line-height: 1.5;
  }

  /* ── CTA Panel ── */
  .elup-cta-panel {
    border-radius: 32px;
    padding: clamp(2.5rem, 5vw, 4rem);
    background: linear-gradient(135deg, #7c3aed, #a78bfa);
    color: var(--lup-navy);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .elup-cta-panel h2 {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #fff;
  }
  .elup-cta-panel p {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    margin-top: 0.5rem;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .elup-event-grid { grid-template-columns: 1fr; }
    .elup-cta-panel { flex-direction: column; text-align: center; }
    .elup-agenda-wrap { padding: 2.5rem 1.5rem; }
  }
  @media (max-width: 600px) {
    .elup-hero {
      padding: 12rem 0 2rem;
      border-radius: 0 0 30px 30px;
    }
    .elup-hero-logo { height: 60px; margin-bottom: 1.2rem; }
    .elup-hero h1 { font-size: clamp(3rem, 14vw, 5rem); }
    .elup-event-grid { grid-template-columns: 1fr; gap: 1rem; }
  }
</style>
