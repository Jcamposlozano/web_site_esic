---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/sections/PageHero.astro";
import ContentSection from "../components/sections/ContentSection.astro";
import HighlightSection from "../components/sections/HighlightSection.astro";
import FormPlaceholder from "../components/sections/FormPlaceholder.astro";

const agenda = [
  { hora: "9:00 am", title: "Bienvenida & desayuno", body: "Recibimiento, networking inicial y café." },
  { hora: "9:30 am", title: "Charla institucional", body: "Visión ESIC, programas y modelo educativo." },
  { hora: "10:00 am", title: "Recorrido por el campus", body: "Tour guiado por aulas, Tech Lab y áreas comunes." },
  { hora: "11:00 am", title: "Sesión muestra", body: "Vive una clase real con uno de nuestros docentes." },
  { hora: "11:45 am", title: "Q&A con admisiones", body: "Resuelve dudas sobre programas, becas y proceso." },
];
---
<Layout title="Open Day ESIC Medellín">
  <PageHero
    eyebrow="Open Day · Sábado 30 de mayo"
    title="Una mañana para<br />vivir <span class='text-brand-orange'>ESIC</span>"
    subtitle="Sábado 30 de mayo · 9:00am a 12:00pm · Campus ESIC Medellín. Conoce el campus, vive una clase muestra y conversa con admisiones."
    ctas={[{ label: "Inscríbete al Open Day", href: "#inscripcion" }]}
    image="/images/wp/2026/05/open-day-home-desktop-scaled.webp"
    imageMobile="/images/wp/2026/05/open-day-home-mobile-scaled.webp"
  />

  <ContentSection
    z={2}
    eyebrow="¿Por qué venir?"
    eyebrowColor="text-brand-orange"
    title="Una mañana para vivir ESIC"
  >
    <div class="grid gap-6 md:grid-cols-3 mt-6">
      <article class="bg-white rounded-3xl p-8 border border-[rgba(0,19,63,0.06)]">
        <h3 class="font-display text-lg font-extrabold uppercase text-brand-blue-dark mb-3">Conoce el campus</h3>
        <p class="text-ink-muted leading-relaxed">Recorrido por aulas, Tech Lab y áreas comunes con uno de nuestros guías.</p>
      </article>
      <article class="bg-white rounded-3xl p-8 border border-[rgba(0,19,63,0.06)]">
        <h3 class="font-display text-lg font-extrabold uppercase text-brand-blue-dark mb-3">Vive una clase</h3>
        <p class="text-ink-muted leading-relaxed">Sesión muestra con un docente ESIC: el formato real de aprendizaje.</p>
      </article>
      <article class="bg-white rounded-3xl p-8 border border-[rgba(0,19,63,0.06)]">
        <h3 class="font-display text-lg font-extrabold uppercase text-brand-blue-dark mb-3">Habla con admisiones</h3>
        <p class="text-ink-muted leading-relaxed">Resuelve dudas sobre programas, becas, financiación y proceso.</p>
      </article>
    </div>
  </ContentSection>

  <ContentSection
    z={3}
    bg="bg-bg-alt"
    eyebrow="Lo que vas a vivir"
    eyebrowColor="text-brand-orange"
    title="Agenda del día"
  >
    <div class="space-y-3 mt-6 max-w-[760px]">
      {agenda.map((a) => (
        <article class="flex gap-5 items-start bg-white rounded-2xl p-6 border border-[rgba(0,19,63,0.06)]">
          <div class="shrink-0 w-24 font-display font-extrabold text-brand-orange text-lg uppercase">{a.hora}</div>
          <div>
            <h3 class="font-display text-lg font-extrabold uppercase text-brand-blue-dark mb-1">{a.title}</h3>
            <p class="text-ink-muted leading-relaxed">{a.body}</p>
          </div>
        </article>
      ))}
    </div>
  </ContentSection>

  <HighlightSection
    z={4}
    color="orange"
    eyebrow="Asegura tu cupo"
    title="Inscríbete al Open Day"
    body="Cupos limitados. Inscríbete cuanto antes para confirmar tu asistencia."
    ctas={[{ label: "Inscribirme ahora", href: "#inscripcion" }]}
  />

  <div id="inscripcion"></div>
  <FormPlaceholder z={5} title="Inscríbete al Open Day" />
</Layout>
