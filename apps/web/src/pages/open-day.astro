---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import ContactFormSection from "../components/sections/ContactFormSection.astro";
import { asset } from "../lib/assets";

const title = "Open Day — ESIC Medellín | Sábado 30 de mayo de 2026";
const description =
  "Vive el Open Day de ESIC Medellín. Explora carreras, conecta con estudiantes y descubre el futuro. Sábado 30 de mayo de 2026, 9:00 a.m. – 12:00 m.";

const infoCards = [
  {
    label: "Fecha",
    value: "Sábado 30 de mayo",
    extra: "2026",
    icon: `<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
  },
  {
    label: "Hora",
    value: "9:00 a.m. – 12:00 m.",
    extra: "Bienvenida puntual",
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  },
  {
    label: "Lugar",
    value: "Campus ESIC Medellín",
    extra: "Km 17 Vía Las Palmas — Mall La Reserva",
    icon: `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>`,
  },
];

const agenda = [
  {
    time: "9:00 — 9:30 a.m.",
    title: "Bienvenida y presentación ESIC",
    speakers: [
      { name: "Yurani Sánchez", role: "Directora Académica Pregrados" },
      { name: "Juan Esteban Jaramillo", role: "CEO ESIC Medellín" },
    ],
  },
  {
    time: "9:30 — 10:30 a.m.",
    title: "Panel de emprendimiento y profesiones",
    speakers: [
      { name: "Sebastián Chinkovsky", role: "Co-fundador de NEWO · Creador de OBMO y MENTE 2.0" },
    ],
  },
  {
    time: "10:30 — 11:00 a.m.",
    title: "Innovación Abierta",
    speakers: [
      { name: "Juan Sebastián Rodríguez", role: "Docente y Líder de Relacionamiento Empresarial" },
    ],
  },
  {
    time: "11:00 — 11:45 a.m.",
    title: "Reto para la Gen Z",
    speakers: [{ name: "Jerónimo Martínez", role: "Fábrica de Inteligencia Artificial ESIC" }],
  },
  {
    time: "11:45 — 11:50 a.m.",
    title: "Premiación Beca",
    speakers: [{ name: "Yurani Sánchez", role: "Directora Académica Pregrados" }],
  },
  {
    time: "11:50 — 12:00 m.",
    title: "Visita guiada",
    speakers: [{ name: "Tatiana Serna", role: "Analista Pregrados" }],
  },
];
---
<Layout title={title} description={description} fullBleed>
  <main class="esic-open-day bg-bg">
    <!-- HERO -->
    <section class="relative z-[1] block">
      <picture>
        <source media="(max-width: 767px)" srcset={asset("wp/2026/05/open-day-banner-mobile-scaled.webp")} />
        <img
          src={asset("wp/2026/05/open-day-banner-desktop-scaled.webp")}
          alt="Vive el Open Day - ESIC Medellín"
          class="block h-auto w-full"
          fetchpriority="high"
        />
      </picture>
    </section>

    <!-- CUÁNDO Y DÓNDE -->
    <section class="relative z-[2] -mt-[50px] rounded-t-[50px] bg-bg py-20 md:py-24">
      <Container class="max-w-[1100px]">
        <div class="mb-12 text-center">
          <span class="mb-3.5 inline-block text-[0.78rem] font-bold uppercase tracking-[0.18em] text-brand-orange-alt">
            Sábado 30 de mayo de 2026
          </span>
          <h2 class="font-display text-[clamp(2.2rem,5.5vw,3.6rem)] font-extrabold uppercase text-brand-blue-dark">
            Una mañana para vivir ESIC
          </h2>
          <p class="mx-auto mt-3 max-w-[640px] text-[1.05rem] leading-[1.6] text-ink-muted">
            Explora carreras, conecta con estudiantes y descubre cómo se ve el futuro cuando empiezas a construirlo hoy.
          </p>
        </div>

        <div class="mb-12 grid grid-cols-1 gap-5 md:grid-cols-3">
          {infoCards.map((card) => (
            <div class="eod-card rounded-[18px] border border-[rgba(0,19,63,0.12)] bg-white p-8 transition-all">
              <div class="mb-[1.1rem] grid h-[46px] w-[46px] place-items-center rounded-[12px] bg-[rgba(255,135,1,0.12)] text-brand-orange-alt">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-[22px] w-[22px]" set:html={card.icon} />
              </div>
              <div class="mb-1.5 text-[0.72rem] font-bold uppercase tracking-[0.14em] text-ink-light">{card.label}</div>
              <div class="mb-1.5 font-display text-[1.55rem] font-bold uppercase leading-[1.1] tracking-[0.01em] text-brand-blue-dark">{card.value}</div>
              <div class="text-[0.92rem] leading-[1.5] text-ink-muted">{card.extra}</div>
            </div>
          ))}
        </div>

        <div class="text-center">
          <a
            href="#eod-formulario"
            class="inline-flex items-center justify-center gap-2.5 rounded-full border-2 border-brand-orange-alt bg-brand-orange-alt px-[2.4rem] py-[1.1rem] text-[0.85rem] font-bold uppercase tracking-[0.08em] text-white no-underline transition-all hover:-translate-y-0.5 hover:border-[#E67700] hover:bg-[#E67700]"
          >
            Inscríbete ahora
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-[18px] w-[18px]">
              <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
        </div>
      </Container>
    </section>

    <!-- AGENDA DEL DÍA -->
    <section class="relative z-[3] -mt-[50px] rounded-t-[50px] bg-white py-20 md:py-24">
      <Container class="max-w-[1100px]">
        <div class="mb-12 text-center">
          <span class="mb-3.5 inline-block text-[0.78rem] font-bold uppercase tracking-[0.18em] text-brand-orange-alt">
            Agenda del día
          </span>
          <h2 class="font-display text-[clamp(2.2rem,5.5vw,3.6rem)] font-extrabold uppercase text-brand-blue-dark">
            Lo que vas a vivir
          </h2>
          <p class="mx-auto mt-3 max-w-[640px] text-[1.05rem] leading-[1.6] text-ink-muted">
            Tres horas pensadas para que conozcas el campus, los programas y la forma en que ESIC prepara a la próxima generación de líderes.
          </p>
        </div>

        <ul class="eod-agenda-list ml-2 flex flex-col border-l-2 border-[rgba(255,135,1,0.22)] pl-8">
          {agenda.map((item) => (
            <li class="eod-agenda-item relative border-b border-[rgba(0,19,63,0.12)] py-[1.15rem] pl-4 last:border-none">
              <span class="mb-1 block font-display text-[1.05rem] font-bold uppercase tracking-[0.04em] text-brand-orange-alt">{item.time}</span>
              <h3 class="mb-1.5 font-display text-[1.5rem] font-extrabold uppercase leading-[1.05] text-brand-blue-dark">{item.title}</h3>
              <p class="text-[0.95rem] leading-[1.55] text-ink-muted">
                {item.speakers.map((sp, i) => (
                  <Fragment>
                    {i > 0 && <br />}
                    <strong class="font-bold text-brand-blue-dark">{sp.name}</strong>{" "}
                    <span class="text-[0.88rem] text-ink-light">· {sp.role}</span>
                  </Fragment>
                ))}
              </p>
            </li>
          ))}
        </ul>

        <p class="mt-10 rounded-[12px] border-l-[3px] border-brand-blue bg-[rgba(0,71,233,0.06)] px-[1.6rem] py-[1.4rem] text-[0.98rem] leading-[1.6] text-ink">
          En paralelo, contaremos con estudiantes de ambas carreras disponibles para resolver dudas y brindar asesoría sobre las diferencias entre las dos profesiones.
        </p>
      </Container>
    </section>

    <!-- FORMULARIO -->
    <div id="eod-formulario"></div>
    <ContactFormSection
      z={4}
      bg="bg-bg"
      title="Inscríbete al Open Day"
      body="Cupos limitados. Completa tus datos y te confirmaremos tu participación por correo y WhatsApp para el Open Day del sábado 30 de mayo de 2026."
      formLabel="Formulario Zoho · Open Day 2026"
    />
  </main>
</Layout>

<style>
  /* Timeline dots — el ::before posicionado es difícil de reproducir 1:1 en Tailwind */
  .esic-open-day .eod-agenda-item::before {
    content: "";
    position: absolute;
    left: -2.55rem;
    top: 1.65rem;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-brand-orange-alt);
    box-shadow: 0 0 0 4px rgba(255, 135, 1, 0.18);
  }
  .esic-open-day .eod-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(0, 19, 63, 0.08);
    border-color: rgba(255, 135, 1, 0.35);
  }
  @media (max-width: 768px) {
    .esic-open-day .eod-agenda-list {
      padding-left: 1.5rem;
    }
    .esic-open-day .eod-agenda-item::before {
      left: -2.05rem;
    }
  }
</style>
