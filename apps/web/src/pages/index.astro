---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import OverlapSection from "../components/OverlapSection.astro";
import BannerCarousel from "../components/home/BannerCarousel.tsx";
import PorqueSection from "../components/home/PorqueSection.astro";
import ProgramasSection from "../components/home/ProgramasSection.tsx";
import CampusRompescroll from "../components/home/CampusRompescroll.astro";
import CifrasSection from "../components/home/CifrasSection.astro";
import HistoriasSection from "../components/home/HistoriasSection.astro";
import FundadoresMarquee from "../components/home/FundadoresMarquee.astro";
import RethinkSection from "../components/home/RethinkSection.tsx";
import { allPosts, postHref } from "../lib/posts";

// Cards del Rethink desde las noticias de S3 (orden ya viene por publishedAt desc).
const rethinkCards = allPosts.map((p) => ({
  category: p.category,
  image: p.coverUrl,
  tag: p.category === "podcast" ? "Podcast" : "Blog",
  title: p.title,
  href: postHref(p),
  external: Boolean(p.externalUrl),
  ctaLabel: p.category === "podcast" ? "Escuchar" : "Leer",
}));
---
<Layout title="ESIC Medellín — Business & Marketing School" fullBleed>
  <main class="esic-home">
    <BannerCarousel client:load />

    <PorqueSection z={2} />

    <OverlapSection bg="bg-[#F5F5F7]" z={3} padding="py-20 md:py-24" class="programas-anchor">
      <Container>
        <ProgramasSection client:load />
      </Container>
    </OverlapSection>

    <CampusRompescroll z={4} />

    <CifrasSection z={5} />

    <HistoriasSection z={6} />

    <FundadoresMarquee z={7} />

    <OverlapSection bg="bg-brand-blue-dark" z={8} padding="py-20 md:py-24" textColor="text-white">
      <Container>
        <RethinkSection client:load cards={rethinkCards} />
      </Container>
    </OverlapSection>
  </main>
</Layout>
