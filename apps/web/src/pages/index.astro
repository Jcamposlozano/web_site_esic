---
import Layout from "../layouts/Layout.astro";
---
<Layout title="ESIC Medell&iacute;n — Business &amp; Marketing School">
  <main class="min-h-dvh grid place-items-center px-6">
    <section class="text-center max-w-2xl">
      <p class="text-sm tracking-[0.22em] uppercase font-bold text-brand-blue mb-4">
        Fase 0 — Setup
      </p>
      <h1 class="text-6xl md:text-8xl font-display font-extrabold text-brand-blue-dark">
        ESIC
        <span class="block text-brand-orange">React Migration</span>
      </h1>
      <p class="mt-6 text-lg text-ink-muted font-body">
        Stack listo: Astro 5 + React 19 + Tailwind v4. Tokens del design system cargados.
        Pr&oacute;ximo paso: librer&iacute;a de componentes y migraci&oacute;n del homepage.
      </p>

      <div class="mt-10 inline-flex flex-wrap gap-3 justify-center">
        <span class="rounded-full px-4 py-2 bg-brand-blue text-white text-sm font-semibold">brand-blue</span>
        <span class="rounded-full px-4 py-2 bg-brand-teal text-brand-blue-dark text-sm font-semibold">brand-teal</span>
        <span class="rounded-full px-4 py-2 bg-brand-orange text-white text-sm font-semibold">brand-orange</span>
        <span class="rounded-full px-4 py-2 bg-bg-alt text-ink text-sm font-semibold border border-ink/10">bg-alt</span>
      </div>
    </section>
  </main>
</Layout>
