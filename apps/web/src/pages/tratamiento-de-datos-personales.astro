---
/**
 * /tratamiento-de-datos-personales — contenido migrado desde
 * esic.co/tratamiento-de-datos-personales.
 *
 * NOTA: reproduce el texto de autorización publicado en la web. Validar con el
 * documento oficial de PRISMA COLOMBIA S.A.S. antes de producción si se requiere
 * literalidad jurídica exacta.
 */
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";

const clausulas = [
  {
    n: "Primero",
    body: [
      "De forma libre y voluntaria autorizo a PRISMA COLOMBIA S.A.S., en calidad de responsable del tratamiento, para recolectar, almacenar, usar y, en general, tratar mis datos personales de acuerdo con su política de protección de datos.",
      "PRISMA COLOMBIA S.A.S. podrá encargar el tratamiento a terceros, manteniendo las instrucciones y medidas de seguridad apropiadas.",
    ],
  },
  {
    n: "Segundo",
    body: [
      "La autorización cubre el tratamiento de los datos para: el cumplimiento de las obligaciones contractuales, el cumplimiento de obligaciones legales, comunicaciones comerciales, informar sobre el estado y novedades de la institución, transferir o transmitir las bases de datos a terceros, atender peticiones, quejas y reclamos, y registrar el ingreso de visitantes.",
      "Adicionalmente, autorizo el tratamiento de mi imagen, voz, nombre y atributos identificables captados mediante fotografías, grabaciones de audio, video, transmisión en vivo u otros medios, durante actividades académicas, institucionales, culturales, comerciales o promocionales vinculadas a ESIC Medellín.",
      "PRISMA COLOMBIA S.A.S. y ESIC Medellín podrán reproducir, publicar, comunicar públicamente, distribuir y transformar dicho material en canales físicos y digitales, sin limitación territorial y sin contraprestación económica.",
    ],
  },
  {
    n: "Tercero",
    body: [
      "Como titular de los datos conservo el derecho a conocer, actualizar y rectificar mi información personal; solicitar prueba de la autorización otorgada; recibir información sobre el uso de mis datos; presentar quejas ante la autoridad competente; revocar la autorización; y acceder a mis datos personales de forma gratuita.",
    ],
  },
  {
    n: "Cuarto",
    body: [
      "La especificación completa del uso de los datos personales se encuentra en la Política para el Tratamiento de Datos Personales de PRISMA COLOMBIA S.A.S., disponible en www.esic.co.",
    ],
  },
];
---
<Layout title="Tratamiento de Datos Personales — ESIC Medellín" description="Autorización para el tratamiento de datos personales de ESIC Medellín conforme a la Ley 1581 de 2012.">
  <main>
    <section class="relative bg-brand-blue-dark text-white pt-32 pb-20 md:pt-40 md:pb-24">
      <Container>
        <span class="inline-flex items-center gap-3 text-[0.74rem] font-bold uppercase tracking-[0.22em] text-brand-teal mb-4">
          <span class="block h-px w-8 bg-current" aria-hidden="true"></span>
          Legal
        </span>
        <h1 class="font-display font-extrabold uppercase leading-[0.95] text-[clamp(2.25rem,5.5vw,4rem)]">
          Autorización para el<br />Tratamiento de Datos
        </h1>
        <p class="mt-5 max-w-[62ch] text-[1.05rem] leading-[1.6] text-white/85">
          El presente documento otorga autorización expresa a PRISMA COLOMBIA S.A.S. para el
          tratamiento de datos personales, conforme a la Ley 1581 de 2012 y el Decreto 1377 de 2013
          de la República de Colombia.
        </p>
      </Container>
    </section>

    <section class="relative z-[2] -mt-[50px] rounded-t-[50px] bg-white py-16 md:py-20">
      <Container>
        <article class="legal-prose max-w-[820px]">
          {clausulas.map((c) => (
            <div class="legal-clausula">
              <h2>{c.n}</h2>
              {c.body.map((p) => <p>{p}</p>)}
            </div>
          ))}
          <p class="mt-8">
            Consulta también nuestras
            <a href="/politicas-de-privacidad/"> Políticas de Privacidad</a>.
          </p>
        </article>
      </Container>
    </section>
  </main>
</Layout>

<style>
  .legal-prose { font-family: var(--font-body); color: var(--color-ink-muted); line-height: 1.7; }
  .legal-clausula { margin-bottom: 2rem; }
  .legal-prose h2 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--color-brand-blue);
    margin: 0 0 0.75rem;
  }
  .legal-prose p { margin: 0 0 1rem; }
  .legal-prose a { color: var(--color-brand-blue); text-decoration: underline; }
</style>
