---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/sections/PageHero.astro";
import ContentSection from "../components/sections/ContentSection.astro";
import HighlightSection from "../components/sections/HighlightSection.astro";
import FormPlaceholder from "../components/sections/FormPlaceholder.astro";

const razones = [
  { title: "Aprende ejecutando", body: "No es teoría: armas tu idea con metodologías de empresas reales." },
  { title: "Mentores con experiencia", body: "Acompañamiento de founders y líderes del ecosistema." },
  { title: "Networking real", body: "Conoces inversores, otros founders y comunidad emprendedora local." },
  { title: "Recursos posteriores", body: "Acceso a la red ESIC, alianzas, espacios y oportunidades de inversión." },
];

const agenda = [
  { hora: "9:00 am", title: "Apertura & desayuno", body: "Networking inicial entre participantes y mentores." },
  { hora: "9:30 am", title: "Charla principal", body: "Visión, oportunidades y casos de éxito del ecosistema." },
  { hora: "10:30 am", title: "Workshops paralelos", body: "Idea validation, modelo de negocio, pitch deck." },
  { hora: "12:30 pm", title: "Mentorías 1:1", body: "Sesiones individuales con founders y mentores invitados." },
  { hora: "2:00 pm", title: "Demo Day & cierre", body: "Presentaciones cortas y cierre con la comunidad." },
];
---
<Layout title="Start-Up Day ESIC Medellín">
  <PageHero
    eyebrow="Start-Up Day"
    title="<span class='text-brand-orange'>Start-Up</span> Day"
    subtitle="Un día completo para entrar al ecosistema emprendedor. Workshops, mentorías y networking con founders y líderes."
    ctas={[{ label: "Inscríbete", href: "#inscripcion" }]}
  />

  <ContentSection
    z={2}
    eyebrow="Dos formatos"
    eyebrowColor="text-brand-orange"
    title="Dos formas de vivir el Start-Up Day"
  >
    <div class="grid gap-6 md:grid-cols-2 mt-6">
      <article class="bg-white rounded-3xl p-8 border border-[rgba(0,19,63,0.06)] shadow-[0_2px_20px_rgba(0,19,63,0.05)]">
        <span class="inline-flex items-center text-[0.7rem] font-bold uppercase tracking-[0.18em] text-brand-orange mb-3">Para founders</span>
        <h3 class="font-display text-2xl font-extrabold uppercase text-brand-blue-dark mb-3">Ya tienes una idea</h3>
        <p class="text-ink-muted leading-relaxed">Workshops avanzados, pitch coaching y mentorías individuales para llevarla al siguiente nivel.</p>
      </article>
      <article class="bg-white rounded-3xl p-8 border border-[rgba(0,19,63,0.06)] shadow-[0_2px_20px_rgba(0,19,63,0.05)]">
        <span class="inline-flex items-center text-[0.7rem] font-bold uppercase tracking-[0.18em] text-brand-orange mb-3">Para exploradores</span>
        <h3 class="font-display text-2xl font-extrabold uppercase text-brand-blue-dark mb-3">Estás explorando</h3>
        <p class="text-ink-muted leading-relaxed">Charlas inspiracionales, dinámicas de validación y conexión con la comunidad emprendedora.</p>
      </article>
    </div>
  </ContentSection>

  <ContentSection
    z={3}
    bg="bg-bg-alt"
    eyebrow="Razones para no quedarte por fuera"
    eyebrowColor="text-brand-orange"
    title="Por qué venir"
  >
    <div class="grid gap-6 md:grid-cols-2 mt-6">
      {razones.map((r) => (
        <article class="bg-white rounded-3xl p-8 border border-[rgba(0,19,63,0.06)]">
          <h3 class="font-display text-xl font-extrabold uppercase text-brand-blue-dark mb-3">{r.title}</h3>
          <div class="w-10 h-[2px] bg-brand-orange mb-4"></div>
          <p class="text-ink-muted leading-relaxed">{r.body}</p>
        </article>
      ))}
    </div>
  </ContentSection>

  <ContentSection
    z={4}
    eyebrow="Lo que vas a vivir"
    eyebrowColor="text-brand-orange"
    title="Agenda del día"
  >
    <div class="space-y-3 mt-6 max-w-[760px]">
      {agenda.map((a) => (
        <article class="flex gap-5 items-start bg-white rounded-2xl p-6 border border-[rgba(0,19,63,0.06)]">
          <div class="shrink-0 w-24 font-display font-extrabold text-brand-orange text-lg uppercase">{a.hora}</div>
          <div>
            <h3 class="font-display text-lg font-extrabold uppercase text-brand-blue-dark mb-1">{a.title}</h3>
            <p class="text-ink-muted leading-relaxed">{a.body}</p>
          </div>
        </article>
      ))}
    </div>
  </ContentSection>

  <HighlightSection
    z={5}
    color="orange"
    eyebrow="Asegura tu lugar"
    title="Inscríbete al<br />Start-Up Day"
    ctas={[{ label: "Inscribirme ahora", href: "#inscripcion" }]}
  />

  <div id="inscripcion"></div>
  <FormPlaceholder z={6} title="Inscríbete al Start-Up Day" />
</Layout>
