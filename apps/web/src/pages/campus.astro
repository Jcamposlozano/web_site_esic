---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/sections/PageHero.astro";
import ContentSection from "../components/sections/ContentSection.astro";
import HighlightSection from "../components/sections/HighlightSection.astro";

const areas = [
  {
    title: "Auditorio",
    desc: "Espacio principal para conferencias, foros y graduaciones. Capacidad para eventos académicos y corporativos.",
    image: "/images/wp/2026/04/areas-comunes-08.webp",
  },
  {
    title: "Tech Lab",
    desc: "Laboratorio digital con tecnología de punta para proyectos de transformación digital, IA y data.",
    image: "/images/wp/2026/04/piso-2-07.webp",
  },
  {
    title: "Áreas comunes",
    desc: "Lounges, cowork y espacios colaborativos pensados para networking y trabajo en equipo.",
    image: "/images/wp/2026/04/areas-comunes-03.webp",
  },
  {
    title: "Salones",
    desc: "Aulas modulares y configurables, diseñadas para metodologías activas y trabajo por proyectos.",
    image: "/images/wp/2026/04/piso-2-03.webp",
  },
  {
    title: "Vista al exterior",
    desc: "Vistas privilegiadas sobre el oriente antioqueño desde un campus pensado para inspirar.",
    image: "/images/wp/2026/04/campus-exterior-05.webp",
  },
  {
    title: "Espacios sociales",
    desc: "Zonas de descanso, cafetería y áreas de encuentro para la comunidad ESIC.",
    image: "/images/wp/2026/04/piso-menos1-05.webp",
  },
];
---
<Layout title="Nuestro Campus — ESIC Medellín">
  <PageHero
    eyebrow="Campus ESIC Medellín"
    title="Un campus diseñado<br />para formar líderes en <span class='text-brand-teal'>Medellín</span>"
    subtitle="Auditorio, Tech Lab, áreas comunes y salones pensados para impulsar la creatividad, la innovación y el aprendizaje experiencial. En el corazón del Oriente Antioqueño."
    ctas={[
      { label: "Agendar visita", href: "/programas/" },
      { label: "Ver programas", href: "/programas/", variant: "outline" },
    ]}
    image="/images/wp/2026/05/BANNER-HOME-CAMPUS-01-scaled.webp"
    eyebrowColor="text-brand-teal"
  />

  <ContentSection
    z={2}
    eyebrow="Un espacio diseñado para"
    title="Inspirar, conectar, transformar"
  >
    <p class="text-[1.05rem] md:text-[1.15rem] leading-[1.7] text-ink-muted max-w-[760px]">
      Cada rincón del campus está pensado para vivir el modelo ESIC: aprendizaje activo, networking
      espontáneo y conexión real con el ecosistema empresarial. No es un edificio académico — es un
      ecosistema profesional.
    </p>
  </ContentSection>

  <ContentSection
    z={3}
    bg="bg-bg-alt"
    eyebrow="Áreas del campus"
    title="Recorrido por nuestros espacios"
  >
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 mt-6">
      {areas.map((a) => (
        <article class="bg-white rounded-3xl overflow-hidden border border-[rgba(0,19,63,0.06)] shadow-[0_2px_20px_rgba(0,19,63,0.05)]">
          <div class="relative aspect-[4/3] overflow-hidden">
            <img src={a.image} alt={a.title} loading="lazy" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-black/25"></div>
          </div>
          <div class="p-6">
            <h3 class="font-display text-xl font-extrabold uppercase text-brand-blue-dark mb-2">{a.title}</h3>
            <p class="text-ink-muted text-[0.95rem] leading-relaxed">{a.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </ContentSection>

  <HighlightSection
    z={4}
    color="blue"
    eyebrow="Encuéntranos en el Oriente"
    title="Km 17 vía Las Palmas<br />Mall La Reserva · Envigado"
    body="Acceso fácil desde Medellín y el área metropolitana. Espacio diseñado para eventos académicos y corporativos."
    ctas={[
      { label: "Agendar visita", href: "/programas/" },
      { label: "Ver en mapa", href: "https://www.google.com/maps/place/Mall+La+Reserva,+Envigado", variant: "outline" },
    ]}
  />
</Layout>
