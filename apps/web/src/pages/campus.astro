---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import CampusGallery from "../components/pages/institucional/CampusGallery.tsx";
import { asset } from "../lib/assets";

const IMG = asset("wp/2026/04");
---
<Layout
  title="Campus ESIC Medellín"
  description="Conoce el campus de ESIC en Medellín: auditorio, áreas comunes, salones por piso y Tech Lab, en un entorno diseñado para el aprendizaje experiencial."
  fullBleed
>
  <!-- ==================== HERO BANNER ==================== -->
  <section class="relative w-full min-h-[85vh] max-[900px]:min-h-[65vh] max-[600px]:min-h-[55vh] flex items-end overflow-hidden">
    <div
      class="absolute inset-0 bg-center bg-cover bg-no-repeat"
      style={`background-image:url('${IMG}/campus-exterior-01.webp')`}
    >
    </div>
    <!-- overlay negro obligatorio -->
    <div
      class="absolute inset-0"
      style="background:linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.45) 55%, rgba(0,0,0,0.85) 100%)"
    >
    </div>
    <Container class="relative z-[2] pb-20 max-[900px]:pb-14 text-white">
      <span
        class="inline-block bg-brand-blue-dark text-white text-[0.8rem] font-bold uppercase tracking-[0.1em] px-4 py-1.5 rounded-full mb-5"
        >Campus ESIC Medellín</span
      >
      <h1
        class="font-display font-extrabold uppercase leading-[1.05] text-[clamp(2.5rem,6vw,5rem)] max-w-[800px] [text-shadow:0_4px_24px_rgba(0,0,0,0.75)]"
      >
        Conoce Nuestro <span>Campus</span>
      </h1>
    </Container>
  </section>

  <!-- ==================== SECTION 2: ABOUT + VIDEO ==================== -->
  <section
    class="relative -mt-[50px] max-[900px]:-mt-[30px] rounded-t-[50px] max-[900px]:rounded-t-[30px] bg-surface z-[10]"
  >
    <Container class="py-24 max-[600px]:py-14">
      <div class="grid md:grid-cols-2 gap-16 max-[900px]:gap-8 items-center">
        <div>
          <h2
            class="font-display font-extrabold uppercase text-brand-blue-dark text-[clamp(2rem,4vw,3rem)] leading-[1.1] mb-6"
          >
            Un Espacio Diseñado Para <span>Aprender</span>
          </h2>
          <p class="text-[1.1rem] text-ink-muted leading-[1.75] mb-4">
            El Campus de ESIC en Medellín es un entorno pensado para impulsar la creatividad, la
            innovación y el aprendizaje experiencial. Cada rincón ha sido diseñado para conectar a
            los estudiantes con las herramientas, tecnologías y espacios que necesitan para
            transformar su futuro profesional.
          </p>
          <p class="text-[1.1rem] text-ink-muted leading-[1.75]">
            Desde el auditorio y las áreas comunes hasta los salones por piso y el Tech Lab, nuestras
            instalaciones reflejan el compromiso de ESIC con la excelencia educativa y la formación
            integral de los profesionales del negocio, el marketing y la tecnología.
          </p>
        </div>
        <div
          class="relative rounded-3xl overflow-hidden aspect-[4/3] bg-black shadow-[0_20px_50px_rgba(0,19,63,0.12)]"
        >
          <video
            class="w-full h-full object-cover"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster={`${IMG}/campus-exterior-02.webp`}
          >
            <source src={`${IMG}/Video_campus.mp4`} type="video/mp4" />
          </video>
          <div
            class="absolute inset-0 pointer-events-none"
            style="background:linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.25) 100%)"
          >
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ==================== SECTION 3: CAMPUS AREAS ==================== -->
  <section
    class="relative -mt-[50px] max-[900px]:-mt-[30px] rounded-t-[50px] max-[900px]:rounded-t-[30px] bg-bg z-[12]"
  >
    <Container class="py-20 pb-24 max-[600px]:py-14">
      <div class="text-center mb-12">
        <h2
          class="font-display font-extrabold uppercase text-brand-blue-dark text-[clamp(2rem,4vw,3rem)] mb-3"
        >
          Áreas del <span>Campus</span>
        </h2>
        <p class="text-[1.1rem] text-ink-muted max-w-[640px] mx-auto">
          Recorre cada zona del campus: desde la fachada y las áreas comunes hasta los salones de
          cada piso, el auditorio y el Tech Lab.
        </p>
      </div>
      <CampusGallery client:load />
    </Container>
  </section>

  <!-- ==================== SECTION 4: MAP ==================== -->
  <section
    class="relative -mt-[50px] max-[900px]:-mt-[30px] rounded-t-[50px] max-[900px]:rounded-t-[30px] bg-surface z-[13]"
  >
    <Container class="pt-20 max-[600px]:pt-14">
      <div class="text-center mb-10">
        <h2
          class="font-display font-extrabold uppercase text-brand-blue-dark text-[clamp(2rem,4vw,3rem)] mb-2"
        >
          Encuéntranos en el <span>Mapa</span>
        </h2>
        <p class="text-[1.05rem] text-ink-muted">
          Visita nuestro campus en Medellín y conoce todo lo que tenemos para ti.
        </p>
      </div>

      <div class="flex items-center justify-center gap-3 mb-8">
        <div
          class="w-12 h-12 flex-none bg-brand-blue rounded-full flex items-center justify-center"
        >
          <svg viewBox="0 0 24 24" class="w-6 h-6 fill-white" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"
            ></path>
          </svg>
        </div>
        <span class="text-[1.1rem] font-semibold text-brand-blue-dark"
          >ESIC Business &amp; Marketing School — Medellín, Alto de Palmas</span
        >
      </div>

      <div
        class="rounded-3xl overflow-hidden border-[3px] border-surface shadow-[0_20px_50px_rgba(0,19,63,0.12)] aspect-[16/7] max-[600px]:aspect-[4/3]"
      >
        <iframe
          src="https://maps.google.com/maps?q=ESIC+Business+%26+Marketing+School+Campus+Medell%C3%ADn&hl=es&z=16&output=embed"
          class="w-full h-full border-0"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación del Campus ESIC Medellín"></iframe>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mt-12 pb-20">
        <div
          class="bg-surface rounded-[20px] p-8 px-6 text-center shadow-[0_10px_30px_rgba(0,19,63,0.08)]"
        >
          <svg
            viewBox="0 0 24 24"
            class="w-8 h-8 fill-brand-blue mb-3 mx-auto"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"
            ></path>
          </svg>
          <h4 class="font-display text-[1.1rem] uppercase text-brand-blue-dark mb-1">Dirección</h4>
          <p class="text-[0.95rem] text-ink-muted leading-[1.5]">
            Vía Las Palmas – Aeropuerto José María Córdova<br />Vda. El Peñasco, Envigado, Antioquia
          </p>
        </div>
        <div
          class="bg-surface rounded-[20px] p-8 px-6 text-center shadow-[0_10px_30px_rgba(0,19,63,0.08)]"
        >
          <svg
            viewBox="0 0 24 24"
            class="w-8 h-8 fill-brand-blue mb-3 mx-auto"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10S22 17.52 22 12 17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"
            ></path>
          </svg>
          <h4 class="font-display text-[1.1rem] uppercase text-brand-blue-dark mb-1">Horarios</h4>
          <p class="text-[0.95rem] text-ink-muted leading-[1.5]">
            Lunes a Viernes<br />8:00 AM – 5:00 PM
          </p>
        </div>
      </div>
    </Container>
  </section>
</Layout>
