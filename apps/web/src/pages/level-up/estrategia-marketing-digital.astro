---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/sections/PageHero.astro";
import ContentSection from "../../components/sections/ContentSection.astro";
import BeneficiosGrid from "../../components/sections/BeneficiosGrid.astro";
import HighlightSection from "../../components/sections/HighlightSection.astro";
import FormPlaceholder from "../../components/sections/FormPlaceholder.astro";

const logros = [
  "Diseñar un plan de marketing digital completo, con objetivos medibles.",
  "Manejar las plataformas clave de adquisición y performance.",
  "Construir un funnel de conversión y un sistema de medición.",
  "Tomar decisiones data-driven a partir de tableros y modelos de atribución.",
];

const modulos = [
  { title: "Fundamentos & estrategia", body: "Customer journey, propuesta de valor, segmentación, OKRs digitales." },
  { title: "Adquisición & canales", body: "SEO, SEM, paid social, programmatic, partnerships y orgánico." },
  { title: "Contenido & creatividad", body: "Storytelling, formatos por plataforma, IA aplicada a creatividad." },
  { title: "Analítica & growth", body: "Dashboards, KPIs, atribución, experimentos y retención." },
];
---
<Layout title="Estrategia de Marketing Digital — Level Up — ESIC Medellín">
  <PageHero
    eyebrow="Level Up · Programa corto"
    title="Estrategia de<br /><span class='text-brand-teal'>Marketing Digital</span>"
    subtitle="Programa intensivo para profesionales que necesitan construir y ejecutar un plan completo de marketing digital. Aplicable desde la primera sesión."
    ctas={[{ label: "Solicitar Información", href: "#contacto" }]}
    image="/images/wp/2026/03/level-up-marketing-landing-desktop-scaled.webp"
    imageMobile="/images/wp/2026/03/level-up-marketing-landing-mobile-scaled.webp"
    eyebrowColor="text-brand-teal"
  />

  <BeneficiosGrid
    z={2}
    eyebrow="Lo esencial"
    title="Formato del programa"
    items={[
      { value: "8 semanas", label: "Duración", color: "purple" },
      { value: "Híbrido", label: "Presencial + online", color: "blue" },
      { value: "Mentor", label: "Sesiones 1:1", color: "teal" },
      { value: "Casos reales", label: "Empresas aliadas", color: "orange" },
    ]}
  />

  <ContentSection
    z={3}
    bg="bg-bg-alt"
    eyebrow="Lo que vas a lograr"
    eyebrowColor="text-brand-teal-dark"
    title="Resultados aplicables"
  >
    <ul class="space-y-4 mt-6 max-w-[760px]">
      {logros.map((l) => (
        <li class="flex gap-3 items-start">
          <span class="shrink-0 mt-1 w-5 h-5 rounded-full bg-brand-teal-dark flex items-center justify-center">
            <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3 3 7-7"/></svg>
          </span>
          <span class="text-ink leading-relaxed">{l}</span>
        </li>
      ))}
    </ul>
  </ContentSection>

  <ContentSection
    z={4}
    eyebrow="Contenido del programa"
    eyebrowColor="text-brand-teal-dark"
    title="Cuatro módulos"
  >
    <div class="grid gap-6 md:grid-cols-2 mt-6">
      {modulos.map((m) => (
        <article class="bg-white rounded-3xl p-8 shadow-[0_2px_20px_rgba(0,19,63,0.05)] border border-[rgba(0,19,63,0.05)]">
          <h3 class="font-display text-xl font-extrabold uppercase text-brand-blue-dark mb-3">{m.title}</h3>
          <div class="w-10 h-[2px] bg-brand-teal-dark mb-4"></div>
          <p class="text-ink-muted leading-[1.6]">{m.body}</p>
        </article>
      ))}
    </div>
  </ContentSection>

  <HighlightSection
    z={5}
    color="purple"
    eyebrow="¿Listos para construir?"
    title="Estrategia digital<br />de tu marca"
    body="Sales con un plan ejecutable, las métricas para medirlo y la confianza para defenderlo."
    ctas={[{ label: "Solicitar Información", href: "#contacto" }]}
  />

  <FormPlaceholder z={6} title="Inscríbete al programa" />
</Layout>
