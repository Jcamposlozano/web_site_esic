---
/**
 * /digital-business-transformation — Executive Program (réplica fiel de
 * executive-programs/elementor-widget.html).
 *
 * Hero = banner-image responsive (mobile/desktop) que enlaza a #contacto.
 * El resto del cuerpo es compartido con /executive-programs vía ExecutiveProgramBody.
 *
 * fullBleed: el hero es un banner a ancho completo y el cuerpo usa el patrón
 * de overlap propio del widget (stats bar -50px, etc.), igual que el original.
 */
import Layout from "../layouts/Layout.astro";
import ExecutiveProgramBody from "../components/pages/programas/ExecutiveProgramBody.astro";
import { asset } from "../lib/assets";
---
<Layout
  title="Digital Business Transformation — Executive Program — ESIC Medellín"
  description="Executive Program Digital Business Transformation 2026. 4 meses, inmersión en Madrid, cocreado por ESIC, Prestigio y Accenture."
  fullBleed
>
  <main class="exec-program-widget">
    <!-- Hero Banner -->
    <section class="exec__hero-banner">
      <a href="#contacto" aria-label="Más información sobre Digital Business Transformation">
        <picture>
          <source media="(max-width: 768px)" srcset={asset("wp/2026/03/banner-digital-business-mobile.webp")} type="image/webp" />
          <source media="(min-width: 769px)" srcset={asset("wp/2026/03/banner-digital-business-desktop.webp")} type="image/webp" />
          <img
            src={asset("wp/2026/03/banner-digital-business-desktop.webp")}
            alt="Digital Business Transformation - Executive Program ESIC"
            loading="eager"
          />
        </picture>
      </a>
    </section>

    <ExecutiveProgramBody />
  </main>
</Layout>

<style>
  .exec-program-widget { color: #0B132B; }
  .exec__hero-banner { position: relative; width: 100%; }
  .exec__hero-banner a { display: block; width: 100%; }
  .exec__hero-banner img { width: 100%; height: auto; display: block; }
</style>
