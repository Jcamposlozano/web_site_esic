---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/sections/PageHero.astro";
import ContentSection from "../components/sections/ContentSection.astro";
import BeneficiosGrid from "../components/sections/BeneficiosGrid.astro";
import HighlightSection from "../components/sections/HighlightSection.astro";
import ScrollBreak from "../components/sections/ScrollBreak.astro";
import FormPlaceholder from "../components/sections/FormPlaceholder.astro";

const modulos = [
  { title: "Estrategia CX", body: "Diseño de experiencia, voz del cliente, journey mapping y arquitectura de servicio omnicanal." },
  { title: "Data & insights", body: "Analítica de comportamiento, NPS, segmentación predictiva, modelos de fidelización." },
  { title: "Tecnología de CX", body: "CRM, plataformas de marketing automation, IA conversacional y herramientas de personalización." },
  { title: "Liderazgo de experiencia", body: "Cultura centrada en cliente, OKRs de CX, gestión del cambio y métricas de impacto." },
];
---
<Layout title="Máster en Customer Experience Management — ESIC Medellín">
  <PageHero
    eyebrow="Máster · 11 meses · Modalidad híbrida"
    title="Customer Experience<br /><span class='text-brand-teal'>Management</span>"
    subtitle="Cuando las expectativas cambian, liderar la experiencia del cliente marca la diferencia. Forma a profesionales que diseñan, miden y escalan experiencias memorables."
    ctas={[{ label: "Solicitar Información", href: "#contacto" }]}
    eyebrowColor="text-brand-teal"
  />

  <BeneficiosGrid
    z={2}
    eyebrow="Lo esencial"
    title="Todo lo que necesitas saber"
    items={[
      { value: "11 meses", label: "Duración", color: "teal" },
      { value: "Híbrido", label: "Presencial + online", color: "blue" },
      { value: "ESIC", label: "Doble titulación", color: "orange" },
      { value: "Empresas", label: "Retos reales con aliados", color: "purple" },
    ]}
  />

  <ContentSection
    z={3}
    bg="bg-bg-alt"
    eyebrow="Plan de estudios"
    eyebrowColor="text-brand-teal-dark"
    title="Cuatro módulos integrados"
  >
    <div class="grid gap-6 md:grid-cols-2 mt-6">
      {modulos.map((m) => (
        <article class="bg-white rounded-3xl p-8 shadow-[0_2px_20px_rgba(0,19,63,0.05)] border border-[rgba(0,19,63,0.05)]">
          <h3 class="font-display text-xl font-extrabold uppercase text-brand-blue-dark mb-3">{m.title}</h3>
          <div class="w-10 h-[2px] bg-brand-teal-dark mb-4"></div>
          <p class="text-ink-muted leading-[1.6]">{m.body}</p>
        </article>
      ))}
    </div>
  </ContentSection>

  <ScrollBreak
    z={4}
    eyebrow="Diseñas experiencias reales"
    title="Cada módulo cierra con un<br />proyecto vivido en una<br />empresa del ecosistema"
  />

  <HighlightSection
    z={5}
    color="teal"
    eyebrow="Inversión en tu futuro"
    title="Becas de hasta 40%"
    body="Beneficios por trayectoria, movilidad o convenio corporativo. Conversa con un asesor."
    ctas={[{ label: "Aplicar a una beca", href: "/master/becas/" }]}
  />

  <FormPlaceholder z={6} title="Solicita información del Máster en Customer Experience" />
</Layout>
