# Configuración de despliegue del sitio (S3 + CDN).
# Copia este archivo a .env.deploy y completa los valores reales.
# NO commitees .env.deploy (lleva datos de infraestructura).

# --- AWS / S3 (origen del sitio) ---
# PLACEHOLDER: nombre del bucket destino del sitio. Por confirmar.
S3_BUCKET=PLACEHOLDER-esic-co-web
# Región del bucket (los assets/datos actuales viven en us-east-2).
AWS_REGION=us-east-2
# Prefijo dentro del bucket (déjalo vacío si el sitio va en la raíz del bucket).
S3_PREFIX=

# --- CDN delante del bucket ---
# Elige UNO según el proveedor final (admin portal usa AWS/CloudFront).
# CloudFront:
CLOUDFRONT_DISTRIBUTION_ID=PLACEHOLDER-EXXXXXXXXXXXXX
# Cloudflare (si se usa Cloudflare en vez de CloudFront):
CLOUDFLARE_ZONE_ID=PLACEHOLDER-zone-id
CLOUDFLARE_API_TOKEN=PLACEHOLDER-token
